    var aVals=labels.map(function(k){return A.bkts[k]||0;});
    var bVals=labels.map(function(k){return B.bkts[k]||0;});
    var mx=Math.max.apply(null,aVals.concat(bVals))*1.15||1;
    var pad={t:10,r:10,b:34,l:46};
    var cw=w-pad.l-pad.r,ch=h-pad.t-pad.b;
    var gap=cw/labels.length,bw=gap*0.25;
    ctx.strokeStyle='#e8ede8';ctx.lineWidth=0.5;
    [0.5,1].forEach(function(f){var y=pad.t+ch-ch*f;ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(pad.l+cw,y);ctx.stroke();ctx.fillStyle='#93b09a';ctx.font='10px monospace';ctx.textAlign='right';ctx.fillText(Math.round(mx*f),pad.l-3,y+4);});
    labels.forEach(function(lbl,i){
      var x=pad.l+i*gap+gap*0.1;
      ctx.fillStyle='#22883f';var bh=(aVals[i]/mx)*ch;ctx.fillRect(x,pad.t+ch-bh,bw,bh);
      ctx.fillStyle='rgba(183,119,13,.8)';var bh2=(bVals[i]/mx)*ch;ctx.fillRect(x+bw+2,pad.t+ch-bh2,bw,bh2);
      ctx.fillStyle='#93b09a';ctx.font='10px monospace';ctx.textAlign='center';ctx.fillText(lbl,x+bw,pad.t+ch+14);
    });
  });

  // Generate recommendations for each process
  renderCmpRecs(A, 'a');
  renderCmpRecs(B, 'b');
  renderCrossInsights(A, B);
}

function genCmpRecs(data){
  var recs=[];
  // Bottleneck
  var actList=Object.keys(data.actStats).map(function(a){return {a:a,avg:data.actStats[a].avg,p90:data.actStats[a].p90};});
  actList.sort(function(a,b){return b.avg-a.avg;});
  var topBN=actList[0];
  if(topBN&&topBN.avg/60>1.5){
    recs.push({s:'critical',cat:'Bottleneck',
      title:'Bottleneck: '+topBN.a,
      issue:topBN.a+' averages '+Math.round(topBN.avg)+'m wait (P90: '+Math.round(topBN.p90)+'m).',
      action:'Assign dedicated resource. Set SLA alerts at 2h. Review handoff triggers.',
      impact:'Reducing by 50% saves ~'+Math.round(topBN.avg/60/2*10)/10+'h per case.'});
  }
  // Rework
  if(data.rw>15){
    recs.push({s:data.rw>25?'critical':'warning',cat:'Quality',
      title:'High Rework Rate: '+data.rw.toFixed(1)+'%',
      issue:data.rw.toFixed(1)+'% of cases contain a rejection or rework step (threshold 15%).',
      action:'Audit root causes. Add pre-step quality checks. Review operator training.',
      impact:'Fixing rework for '+Math.round(data.cases*data.rw/100)+' cases reduces total cycle time.'});
  }
  // Long cycle
  if(data.avg>8){
    recs.push({s:'warning',cat:'Cycle Time',
      title:'Avg Cycle Above 8h: '+data.avg.toFixed(1)+'h',
      issue:'Average cycle time of '+data.avg.toFixed(1)+'h is above the 8h target.',
      action:'Focus on top bottleneck. Parallelise independent steps where possible.',
      impact:'Targeting 6h avg would save '+((data.avg-6)*data.cases).toFixed(0)+'h total.'});
  }
  // High P90
  if(data.p90>data.avg*2.5){
    recs.push({s:'warning',cat:'Outliers',
      title:'High P90: '+data.p90.toFixed(1)+'h ('+Math.round(data.p90/data.avg)+'x avg)',
      issue:'P90 cycle time is '+Math.round(data.p90/data.avg)+'x the average - indicates long tail of slow cases.',
      action:'Investigate slowest cases. Check for stuck approvals or missing escalations.',
      impact:'Capping outliers at 2x avg improves P90 significantly.'});
  }
  if(recs.length===0){
    recs.push({s:'ok',cat:'Status',
      title:'Process Looks Healthy',
      issue:'No critical bottlenecks or quality issues detected.',
      action:'Continue monitoring. Compare with baseline periodically.',
      impact:'Maintain current performance levels.'});
  }
  return recs;
}

function renderCmpRecs(data, side){
  var recs=genCmpRecs(data);
  var metaEl=document.getElementById('cmp-'+side+'-rec-meta');
  var listEl=document.getElementById('cmp-'+side+'-recs');
  if(!metaEl||!listEl)return;
  var critCount=recs.filter(function(r){return r.s==='critical';}).length;
  var warnCount=recs.filter(function(r){return r.s==='warning';}).length;
  metaEl.textContent=data.name+' . '+critCount+' critical . '+warnCount+' warnings';
  var h='';
  recs.forEach(function(r){
    var bc=r.s==='critical'?'#c0392b':r.s==='warning'?'#b7770d':r.s==='ok'?'#22883f':'#8aaa8e';
    var bg=r.s==='critical'?'rgba(192,57,43,.05)':r.s==='warning'?'rgba(183,119,13,.05)':'rgba(0,78,43,.04)';
    h+='<div style="border-left:3px solid '+bc+';background:'+bg+';padding:10px 12px;border-radius:0 4px 4px 0;margin-bottom:8px">';
    h+='<div style="display:flex;gap:6px;margin-bottom:5px">';
    h+='<span style="font-size:9px;background:'+bc+';color:#fff;padding:2px 5px;border-radius:2px;font-weight:600;text-transform:uppercase">'+r.s+'</span>';
    h+='<span style="font-size:9px;color:var(--textm);border:1px solid var(--border);padding:2px 5px;border-radius:2px">'+r.cat+'</span></div>';
    h+='<div style="font-size:12px;font-weight:600;color:var(--text);margin-bottom:5px">'+r.title+'</div>';
    h+='<div style="font-size:11px;color:var(--textm);margin-bottom:3px">'+r.issue+'</div>';
    h+='<div style="font-size:11px;color:var(--green);margin-bottom:3px"><b>Action:</b> '+r.action+'</div>';
    h+='<div style="font-size:10px;color:'+bc+';margin-top:5px;padding:4px 8px;background:rgba(0,0,0,.03);border-radius:3px"><b>Impact:</b> '+r.impact+'</div>';
    h+='</div>';
  });
