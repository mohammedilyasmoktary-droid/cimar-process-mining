  flex: 1;
  display: grid;
  grid-template-columns: 1fr auto auto;
  grid-template-rows: auto auto;
  gap: 0 10px;
  padding-bottom: 12px;
  border-bottom: 1px solid rgba(0,0,0,.05);
  align-items: baseline;
