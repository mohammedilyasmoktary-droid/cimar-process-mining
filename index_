}

.org-v-conn { width:1px; height:16px; background:rgba(45,155,94,.3); margin:0 auto; }

/*    DEPT COLUMN                                                          */
.org-dept-col { display:flex; flex-direction:column; align-items:center; transition:opacity .22s ease, transform .22s ease; }

/*    DEPT CARD                                                            */
.org-dept-card {
  width:100%; border-radius:9px;
  border:1px solid rgba(0,0,0,.07);
  background:#eef3ef;
  padding:9px 9px 8px; box-sizing:border-box;
  box-shadow:0 1px 4px rgba(0,0,0,.05), inset 0 1px 0 rgba(255,255,255,.65);
