<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>CIMAR - Process Mining</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f2f4f3;--bg2:#ffffff;--bg3:#f7f9f7;--bg4:#eef2ee;
  --green:#004e2b;--green2:#1a6b35;--green3:#5eac2c;
  --border:#dce6dd;--border2:#b8ccba;
  --text:#1a2e1c;--textm:#557060;--textd:#93b09a;
  --red:#c0392b;--amber:#b7770d;--blue:#1a5fb4;
  --shadow:0 1px 4px rgba(0,78,43,.07);
}
html,body{background:var(--bg);color:var(--text);font-family:Plus Jakarta Sans,sans-serif;font-size:13px;min-height:100vh}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* ALERT STRIP */
#alert-strip{position:fixed;top:0;left:0;right:0;height:36px;background:var(--green);z-index:300;display:flex;align-items:center;padding:0 20px;gap:0;overflow:hidden}
.alert-item{display:flex;align-items:center;gap:8px;padding:0 20px;border-right:1px solid rgba(255,255,255,.15);cursor:pointer;transition:background .15s;height:100%;white-space:nowrap}
.alert-item:hover{background:rgba(255,255,255,.1)}
.alert-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.alert-dot.red{background:#f87171}
.alert-dot.amber{background:#fbbf24}
.alert-dot.green{background:#86efac}
.alert-label{font-size:10px;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:.08em}
.alert-val{font-size:11px;color:#fff;font-family:DM Mono,monospace;font-weight:500}
.alert-action{margin-left:auto;font-size:10px;color:rgba(255,255,255,.6);font-family:DM Mono,monospace;padding:0 16px;cursor:pointer;white-space:nowrap}
.alert-action:hover{color:#fff}

/* TOPBAR */
#topbar{position:fixed;top:36px;left:0;right:0;height:48px;background:#fff;border-bottom:1px solid var(--border);display:flex;align-items:center;z-index:200;box-shadow:0 1px 6px rgba(0,0,0,.05)}
#topbar-logo{width:220px;min-width:220px;display:flex;align-items:center;gap:10px;padding:0 20px;border-right:1px solid var(--border);height:100%}
.brand{font-size:11px;font-weight:600;color:var(--green);letter-spacing:.08em;text-transform:uppercase}
.sub{font-size:9px;color:var(--textd);letter-spacing:.06em;margin-top:1px}
#topbar-ticker{flex:1;display:flex;align-items:center;overflow:hidden;font-family:DM Mono,monospace}
.tick-item{display:flex;align-items:center;gap:6px;padding:0 14px;border-right:1px solid var(--border);height:48px;white-space:nowrap;cursor:default}
.tick-label{font-size:9px;color:var(--textd);text-transform:uppercase;letter-spacing:.08em}
.tick-val{font-size:12px;color:var(--green);font-weight:500}
#topbar-right{padding:0 16px;display:flex;align-items:center;gap:10px;border-left:1px solid var(--border);height:100%;flex-shrink:0}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--green3);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.export-btn{padding:5px 12px;background:var(--green);border:none;border-radius:4px;color:#fff;cursor:pointer;font-size:10px;font-family:DM Mono,monospace;letter-spacing:.08em;text-transform:uppercase;display:flex;align-items:center;gap:5px;transition:background .15s}
.export-btn:hover{background:var(--green2)}
.export-menu{position:absolute;top:84px;right:16px;background:#fff;border:1px solid var(--border);border-radius:6px;box-shadow:0 4px 16px rgba(0,0,0,.12);z-index:500;display:none;min-width:160px;overflow:hidden}
.export-menu.open{display:block}
.export-option{padding:10px 16px;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border)}
.export-option:last-child{border:none}
.export-option:hover{background:var(--bg3)}

/* SIDEBAR */
#sidebar{width:220px;min-width:220px;background:#fff;border-right:1px solid var(--border);position:fixed;top:84px;left:0;bottom:0;display:flex;flex-direction:column;z-index:100;overflow-y:auto}
.sidebar-section{padding:12px 0 6px;border-bottom:1px solid var(--border)}
.sidebar-section-label{font-size:9px;color:var(--textd);letter-spacing:.14em;text-transform:uppercase;padding:0 18px;margin-bottom:6px;font-weight:600}
.nav-item{display:flex;align-items:center;gap:8px;padding:8px 18px;cursor:pointer;font-size:12px;color:var(--textm);border-left:2px solid transparent;transition:all .12s}
.nav-item:hover{color:var(--green);background:rgba(0,78,43,.03)}
.nav-item.active{color:var(--green);background:rgba(0,78,43,.06);border-left:2px solid var(--green);font-weight:500}
.nav-badge{margin-left:auto;font-size:9px;padding:1px 5px;border-radius:10px;font-family:DM Mono,monospace}
.nav-badge.red{background:rgba(192,57,43,.12);color:#c0392b}
.nav-badge.green{background:rgba(94,172,44,.12);color:var(--green2)}
.ss-row{padding:6px 18px;display:flex;justify-content:space-between;align-items:center}
.ss-label{font-size:11px;color:var(--textm)}
/* Department-aware plant highlighting - uses existing design tokens only */
.ss-plant-row{display:flex;align-items:center;padding:5px 18px;gap:0;transition:background .15s}
.ss-plant-row .ss-label{transition:color .15s;font-weight:400}
.ss-plant-row .ss-val{transition:color .15s}


.ss-val{font-family:DM Mono,monospace;font-size:11px;font-weight:500}
.ss-val.red{color:var(--red)}.ss-val.green{color:var(--green)}.ss-val.amber{color:var(--amber)}
.upload-btn{width:100%;padding:8px 0;background:var(--green);border:none;border-radius:4px;color:#fff;cursor:pointer;font-size:10px;font-family:DM Mono,monospace;letter-spacing:.1em;text-transform:uppercase;transition:background .15s}
.logout-btn{
  width:100%;padding:7px 0;
  background:none;
  border:1px solid var(--border);
  border-radius:4px;color:var(--textm);
  cursor:pointer;font-size:10px;
  font-family:DM Mono,monospace;
  letter-spacing:.04em;
  margin-top:7px;
  transition:border-color .15s,color .15s,background .15s;
  display:flex;align-items:center;justify-content:center;gap:6px;
}
.logout-btn:hover{
  border-color:var(--green);
  color:var(--green);
  background:rgba(0,78,43,.04);
}
.logout-btn svg{opacity:.6;transition:opacity .15s;}
.logout-btn:hover svg{opacity:1;}
.upload-btn:hover{background:var(--green2)}

/* MAIN */
#main{margin-left:220px;padding-top:84px;min-height:100vh;background:var(--bg)}
.page{display:none}.page.active{display:block}
.page-content{padding:24px 28px}
#page-dashboard .page-content{padding:0;overflow:hidden;display:flex;flex-direction:column}
.page-header{margin-bottom:20px;display:flex;align-items:flex-start;justify-content:space-between}
.page-header h1{font-size:17px;font-weight:600;color:var(--text)}
.page-header p{font-size:11px;color:var(--textm);margin-top:3px;font-family:DM Mono,monospace}

/* KPI ROW */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid var(--border);border-radius:8px;overflow:hidden;box-shadow:var(--shadow)}
.kpi{background:#fff;padding:10px 16px;position:relative;overflow:hidden;border-right:1px solid var(--border)}
.kpi:last-child{border-right:none}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.kpi.alert::before{background:var(--red)}
.kpi.warn::before{background:var(--amber)}
.kpi.good::before{background:var(--green3)}
.kpi.neutral::before{background:var(--blue)}
.kpi-label{font-size:8px;color:var(--textd);text-transform:uppercase;letter-spacing:.12em;margin-bottom:4px;font-weight:700}
.kpi-value{font-family:DM Mono,monospace;font-size:22px;font-weight:600;line-height:1;letter-spacing:-.02em}
.kpi.alert .kpi-value{color:var(--red)}
.kpi.warn .kpi-value{color:var(--amber)}
.kpi.good .kpi-value{color:var(--green)}
.kpi.neutral .kpi-value{color:var(--blue)}
.kpi-sub{font-size:10px;color:var(--textm);margin-top:6px;font-family:DM Mono,monospace}
.kpi-trend{display:flex;align-items:center;gap:4px;margin-top:10px;font-size:10px;font-family:DM Mono,monospace;padding-top:10px;border-top:1px solid var(--border)}
.kpi-spark{display:flex;align-items:flex-end;gap:2px;height:14px;margin-top:4px}
.spark-bar{width:7px;border-radius:2px;transition:height .3s}
@keyframes countUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.kpi-value.animate{animation:countUp .5s ease forwards}
.hero-status{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.status-card{background:#fff;border:1px solid var(--border);border-radius:10px;padding:20px 22px;box-shadow:0 2px 8px rgba(0,0,0,.04)}
.status-card-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--textd);margin-bottom:14px}
.plant-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--bg4)}
.plant-row:last-child{border-bottom:none}
.plant-name{font-size:12px;color:var(--text);width:90px;flex-shrink:0}
.plant-bar-wrap{flex:1;height:6px;background:var(--bg4);border-radius:3px;overflow:hidden}
.plant-bar-fill{height:100%;border-radius:3px;transition:width .8s cubic-bezier(.4,0,.2,1)}
.plant-val{font-family:DM Mono,monospace;font-size:11px;font-weight:500;width:38px;text-align:right;flex-shrink:0}
.plant-badge{font-size:9px;padding:2px 6px;border-radius:10px;font-family:DM Mono,monospace;font-weight:600;flex-shrink:0}
.activity-status-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--bg4)}
.activity-status-row:last-child{border-bottom:none}
.act-name{font-size:12px;color:var(--text);flex:1}
.act-wait{font-family:DM Mono,monospace;font-size:11px;font-weight:500;width:44px;text-align:right;flex-shrink:0}
.act-bar-wrap{width:120px;height:6px;background:var(--bg4);border-radius:3px;overflow:hidden;flex-shrink:0}
.act-bar-fill{height:100%;border-radius:3px}
.status-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}

/* CARDS */
.card{background:#fff;border:1px solid var(--border);border-radius:8px;padding:18px 20px;margin-bottom:14px;box-shadow:var(--shadow)}
.card-title{font-size:13px;font-weight:600;color:var(--text);margin-bottom:2px}
.card-sub{font-size:10px;color:var(--textm);font-family:DM Mono,monospace;margin-bottom:14px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px}

/* TABLES */
table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:left;padding:7px 10px;color:var(--textd);text-transform:uppercase;letter-spacing:.07em;font-size:10px;border-bottom:1px solid var(--border);font-weight:500}
td{padding:9px 10px;border-bottom:1px solid var(--bg4);color:var(--text)}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(0,78,43,.02)}

/* BARS */
.mbar{background:var(--bg4);border-radius:2px;overflow:hidden}
.mbar-fill{border-radius:2px;transition:width .5s}

/* BADGES */
.badge{display:inline-block;padding:2px 7px;border-radius:3px;font-size:10px;letter-spacing:.05em;text-transform:uppercase;font-weight:500;font-family:DM Mono,monospace}
.bc{background:rgba(192,57,43,.1);color:#c0392b;border:1px solid rgba(192,57,43,.2)}
.bw{background:rgba(183,119,13,.1);color:#b7770d;border:1px solid rgba(183,119,13,.2)}
.bg{background:rgba(0,78,43,.08);color:#004e2b;border:1px solid rgba(0,78,43,.15)}
.bm{background:var(--bg4);color:var(--textm);border:1px solid var(--border)}

/* PROCESS MAP */
#dfg-wrap{width:100%;height:560px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;overflow:hidden;position:relative;cursor:grab}
#dfg-wrap:active{cursor:grabbing}
#dfg-wrap svg{width:100%;height:100%}
.dfg-tooltip{position:absolute;background:#fff;border:1px solid var(--border);border-radius:6px;padding:10px 14px;font-size:11px;pointer-events:none;box-shadow:0 4px 20px rgba(0,0,0,.12);z-index:50;display:none;min-width:180px}
.dfg-tooltip.show{display:block}
.zoom-ctrl{position:absolute;top:10px;right:10px;display:flex;flex-direction:column;gap:4px;z-index:10}
.zoom-btn{width:28px;height:28px;background:#fff;border:1px solid var(--border);border-radius:4px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;color:var(--textm);transition:all .12s;box-shadow:var(--shadow)}
.zoom-btn:hover{background:var(--bg3);color:var(--green)}
.filter-strip{position:absolute;top:10px;left:10px;display:flex;gap:6px;z-index:10}
.filter-chip{padding:4px 10px;background:#fff;border:1px solid var(--border);border-radius:12px;font-size:10px;cursor:pointer;font-family:DM Mono,monospace;color:var(--textm);transition:all .12s;box-shadow:var(--shadow)}
.filter-chip:hover,.filter-chip.active{background:var(--green);color:#fff;border-color:var(--green)}
.map-legend{position:absolute;bottom:10px;left:10px;background:#fff;border:1px solid var(--border);border-radius:6px;padding:8px 12px;display:flex;gap:14px;font-size:10px;color:var(--textm);box-shadow:var(--shadow)}
.legend-dot{width:10px;height:10px;border-radius:2px;display:inline-block;margin-right:4px;vertical-align:middle}

/* BUILDER */
#builder-canvas{width:100%;height:520px;background:#fafcfa;border:1px solid var(--border);border-radius:8px;position:relative;overflow:hidden}
#builder-svg{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none}
.builder-node{position:absolute;width:154px;background:#fff;border:1.5px solid var(--border2);border-radius:8px;cursor:move;user-select:none;padding:10px 12px;box-shadow:0 2px 8px rgba(0,0,0,.07);transition:box-shadow .15s,border-color .15s;z-index:10}
.builder-node:hover{box-shadow:0 4px 16px rgba(0,0,0,.12);border-color:var(--green3)}
.builder-node.selected{border-color:var(--green);box-shadow:0 0 0 3px rgba(0,78,43,.12)}
.node-title{font-size:12px;font-weight:500;color:var(--text);line-height:1.3;pointer-events:none}
.node-meta{font-size:10px;color:var(--textm);margin-top:3px;font-family:DM Mono,monospace;pointer-events:none}
.node-del{position:absolute;top:4px;right:6px;font-size:15px;color:var(--textd);cursor:pointer;line-height:1;opacity:0;transition:opacity .15s;z-index:20}
.builder-node:hover .node-del{opacity:1}
.port{position:absolute;width:18px;height:18px;background:var(--green3);border:3px solid #fff;border-radius:50%;cursor:crosshair;z-index:20;transition:all .15s;box-shadow:0 2px 6px rgba(0,78,43,.3)}
.port:hover{background:var(--green);transform:scale(1.4);box-shadow:0 3px 10px rgba(0,78,43,.4)}
.port.out{bottom:-9px;left:50%;transform:translateX(-50%)}
.port.out:hover{transform:translateX(-50%) scale(1.4)}
.port.in{top:-9px;left:50%;transform:translateX(-50%)}
.port.in:hover{transform:translateX(-50%) scale(1.4)}
.tb-btn{padding:7px 13px;background:#fff;border:1px solid var(--border);border-radius:4px;cursor:pointer;font-size:11px;color:var(--text);font-family:Plus Jakarta Sans,sans-serif;transition:all .12s;display:inline-flex;align-items:center;gap:5px}
.tb-btn:hover{border-color:var(--green);color:var(--green);background:rgba(0,78,43,.03)}
.tb-btn.primary{background:var(--green);color:#fff;border-color:var(--green)}
.tb-btn.primary:hover{background:var(--green2)}
.tb-btn.danger{border-color:rgba(192,57,43,.3);color:var(--red)}
.tb-btn.danger:hover{background:rgba(192,57,43,.05)}
.palette-item{padding:5px 10px;background:var(--bg3);border:1px solid var(--border);border-radius:4px;cursor:pointer;font-size:10px;color:var(--textm);transition:all .12s;user-select:none;display:inline-block}
.palette-item:hover{border-color:var(--green3);color:var(--green);background:rgba(0,78,43,.04)}

/* VARIANTS */
.variant-card{background:#fff;border:1px solid var(--border);border-radius:6px;padding:12px 16px;margin-bottom:8px;cursor:pointer;transition:all .15s}
.variant-card:hover{border-color:var(--green);box-shadow:0 2px 8px rgba(0,78,43,.08)}
.variant-card.selected{border-color:var(--green);background:rgba(0,78,43,.02)}
.vf-node{padding:3px 8px;border-radius:3px;font-size:10px;font-family:DM Mono,monospace;font-weight:500;white-space:nowrap}

/* REC CARDS */
.rec-card{background:#fff;border:1px solid var(--border);border-radius:8px;padding:18px 20px;margin-bottom:12px;box-shadow:var(--shadow)}
.rec-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin:12px 0}
.rbox{background:var(--bg3);border-radius:4px;padding:10px 12px;border:1px solid var(--border)}
.rbox-lbl{font-size:9px;color:var(--textd);text-transform:uppercase;letter-spacing:.1em;margin-bottom:5px;font-weight:600}
.rbox-txt{font-size:12px;color:var(--text);line-height:1.6;white-space:pre-line}
.impact-row{padding:8px 12px;border-radius:4px;background:rgba(0,78,43,.05);border:1px solid rgba(0,78,43,.1);font-size:12px;color:var(--green)}

/* HEATMAP */
.hm-cell{border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:9px;font-family:DM Mono,monospace;font-weight:500;cursor:pointer;transition:transform .12s}
.hm-cell:hover{transform:scale(1.1);z-index:5;position:relative}

/* MODAL */
.modal-ov{display:none;position:fixed;inset:0;background:rgba(0,30,10,.45);z-index:999;align-items:center;justify-content:center;backdrop-filter:blur(3px)}
.modal-ov.open{display:flex}
.modal{background:#fff;border:1px solid var(--border);border-radius:10px;padding:28px;width:460px;max-width:92vw;box-shadow:0 8px 40px rgba(0,0,0,.14)}
.drop-z{display:block;border:2px dashed var(--border2);border-radius:6px;padding:28px;text-align:center;cursor:pointer;background:var(--bg3);transition:border-color .15s}
.drop-z:hover{border-color:var(--green)}
.field-input{width:100%;padding:7px 10px;border:1px solid var(--border);border-radius:4px;font-size:12px;font-family:Plus Jakarta Sans,sans-serif;color:var(--text);background:#fff;outline:none;transition:border-color .15s}
.field-input:focus{border-color:var(--green)}
canvas{display:block;width:100%}

/* COMPARE */
.compare-panel{background:#fff;border:1px solid var(--border);border-radius:8px;padding:18px 20px}
.diff-item{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:4px;margin-bottom:5px;font-size:12px}
.diff-item.missing{background:rgba(192,57,43,.06);border:1px solid rgba(192,57,43,.15);color:var(--red)}
.diff-item.extra{background:rgba(183,119,13,.06);border:1px solid rgba(183,119,13,.15);color:var(--amber)}
.diff-item.match{background:rgba(0,78,43,.04);border:1px solid rgba(0,78,43,.12);color:var(--green)}

/* ANIMATIONS */
@keyframes flowParticle{0%{opacity:0;transform:translateX(0) translateY(0)}20%{opacity:1}80%{opacity:1}100%{opacity:0;transform:translateX(var(--dx)) translateY(var(--dy))}}
.flow-particle{animation:flowParticle 2s linear infinite;animation-delay:var(--delay,0s)}

/*                                                            
   CIMAR PREMIUM ENTRY   4-STEP FLOW
   Step 1: Login  Step 2: Dept Access  Step 3: Intelligence  Step 4: Platform
                                                               */

/*    Design tokens                                                         */
/* =========================================================
   CIMAR ENTRY EXPERIENCE - BULLETPROOF v3
   Login -> Dept Access -> Intelligence -> Platform
   ========================================================= */

/* -- Design tokens (entry screen) -- */
/* =========================================================
   CIMAR PROCESS-MAP INTERFACE v4
   Two views: system topology map + dept process flow
   ========================================================= */

:root {
  --e-forest:   #0c2318;
  --e-green:    #1a4a2e;
  --e-mid:      #2d6b45;
  --e-sage:     #4a9b6b;
  --e-sage-l:   rgba(74,155,107,.1);
  --e-sage-m:   rgba(74,155,107,.18);
  --e-parchment:#f3f4f1;
  --e-paper:    #f9faf7;
  --e-white:    #ffffff;
  --e-ink:      #111a14;
  --e-ink-m:    #3a5044;
  --e-ink-l:    #7a9585;
  --e-ink-xl:   #afc4b6;
  --e-rule:     rgba(0,0,0,.06);
  --e-s1: 0 1px 2px rgba(0,0,0,.05), 0 2px 8px rgba(0,0,0,.04);
  --e-s2: 0 2px 6px rgba(0,0,0,.07), 0 8px 24px rgba(0,0,0,.05);
  --e-s3: 0 4px 14px rgba(0,0,0,.09), 0 18px 44px rgba(0,0,0,.07);
  --ease:      cubic-bezier(.25,.46,.45,.94);
  --ease-out:  cubic-bezier(.16,1,.3,1);
}

/*    Shell                                                 */
#entry-screen {
  position:fixed; inset:0; z-index:9999; overflow:hidden;
  font-family:'Plus Jakarta Sans',sans-serif; background:var(--e-parchment);
}
#entry-screen.hidden { display:none !important; }

/*    Splash                                                 */
#entry-splash {
  position:absolute; inset:0; z-index:10; cursor:pointer;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  background:radial-gradient(ellipse 80% 70% at 50% 38%,#24633c 0%,#163d27 42%,#0b2116 100%);
  overflow:hidden; transition:opacity .8s var(--ease),transform .8s var(--ease);
}
#entry-splash.exit { opacity:0; transform:scale(1.025); pointer-events:none; }
#splash-canvas { position:absolute; inset:0; opacity:.055; pointer-events:none; }
#entry-splash .glow-ring {
  position:absolute; border-radius:50%;
  border:1px solid rgba(74,155,107,.14); pointer-events:none;
}
#entry-splash .glow-ring:nth-child(2){width:500px;height:500px;top:50%;left:50%;transform:translate(-50%,-55%);animation:ringPulse 4s ease-in-out infinite;}
#entry-splash .glow-ring:nth-child(3){width:780px;height:780px;top:50%;left:50%;transform:translate(-50%,-55%);animation:ringPulse 4s ease-in-out 1.4s infinite;}
#entry-splash .glow-ring:nth-child(4){width:1080px;height:1080px;top:50%;left:50%;transform:translate(-50%,-55%);animation:ringPulse 4s ease-in-out 2.8s infinite;}
.splash-logo-wrap {position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:30px;animation:splashIn 1.1s var(--ease-out) both;}
.splash-logo {width:300px;max-width:70vw;display:block;background:#fff;border-radius:14px;padding:22px 40px;box-shadow:0 0 0 1px rgba(255,255,255,.06),0 8px 32px rgba(0,0,0,.28),0 2px 6px rgba(0,0,0,.18);}
.splash-meta {display:flex;flex-direction:column;align-items:center;gap:8px;}
.splash-label {font-size:10px;font-family:'DM Mono',monospace;color:rgba(255,255,255,.38);letter-spacing:.2em;text-transform:uppercase;animation:fadeUp .8s var(--ease-out) .4s both;}
.splash-cta {display:flex;align-items:center;gap:9px;font-size:13px;font-weight:500;color:rgba(255,255,255,.55);animation:fadeUp .8s var(--ease-out) .7s both;}
.splash-cta-dot {width:6px;height:6px;border-radius:50%;background:var(--e-sage);animation:dotPulse 2.4s ease-in-out 1.4s infinite;}

/*    Main entry layout                                      */
#entry-main {
  position:absolute; inset:0; display:flex; flex-direction:row;
  opacity:0; transform:translateY(10px); pointer-events:none;
  transition:opacity .7s var(--ease),transform .7s var(--ease);
}
#entry-main.visible { opacity:1; transform:translateY(0); pointer-events:auto; }

/*    Left brand panel                                        */
.em-left {
  width:340px; min-width:340px; flex-shrink:0; height:100%;
  background:var(--e-green); display:flex; flex-direction:column;
  position:relative; overflow:hidden;
}
.em-left::after {
  content:''; position:absolute; inset:0;
  background:radial-gradient(ellipse 140% 60% at 0% 100%,rgba(12,35,24,.65) 0%,transparent 55%),
             radial-gradient(ellipse 80% 50% at 100% 0%,rgba(74,155,107,.07) 0%,transparent 50%);
  pointer-events:none;
}
.em-left-inner {position:relative;z-index:1;display:flex;flex-direction:column;height:100%;padding:36px 40px 40px;}
.em-left-logo {background:#fff;border-radius:12px;padding:16px 24px;display:inline-flex;align-items:center;width:fit-content;box-shadow:0 4px 24px rgba(0,0,0,.22),0 1px 4px rgba(0,0,0,.14);}
.em-left-logo img {height:52px;width:auto;display:block;max-width:220px;}
.em-left-body {flex:1;display:flex;flex-direction:column;justify-content:center;padding:32px 0 28px;}
.em-dept-count {font-size:10px;font-family:'DM Mono',monospace;color:var(--e-sage);text-transform:uppercase;letter-spacing:.14em;margin-bottom:14px;}
.em-headline {font-size:36px;font-weight:700;color:#fff;letter-spacing:-.04em;line-height:1.08;margin-bottom:14px;}
.em-headline-accent {display:block;font-weight:300;opacity:.75;}
.em-sub {font-size:12px;color:rgba(255,255,255,.42);font-family:'DM Mono',monospace;line-height:1.8;margin-bottom:36px;max-width:240px;}
.em-divider {width:28px;height:1px;background:rgba(255,255,255,.16);margin-bottom:24px;}
.em-stats {display:flex;flex-direction:column;gap:6px;}
.em-stat {display:flex;align-items:baseline;gap:12px;padding:10px 14px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.07);border-radius:8px;transition:background .2s;}
.em-stat:hover {background:rgba(255,255,255,.08);}
.em-stat-val {font-size:17px;font-weight:700;color:#fff;font-family:'DM Mono',monospace;min-width:42px;letter-spacing:-.02em;}
.em-stat-label {font-size:11px;color:rgba(255,255,255,.42);line-height:1.3;}
.em-period {margin-top:24px;font-size:10px;font-family:'DM Mono',monospace;color:rgba(255,255,255,.22);letter-spacing:.08em;display:flex;align-items:center;gap:8px;}
.em-period-dot {width:5px;height:5px;border-radius:50%;background:var(--e-sage);opacity:.65;}

/*    Right views area                                        */
.em-right {flex:1;overflow:hidden;display:flex;flex-direction:column;background:var(--e-parchment);position:relative;}
.em-view {position:absolute;inset:0;overflow-y:auto;opacity:0;transform:translateX(14px);pointer-events:none;transition:opacity .38s var(--ease),transform .38s var(--ease);}
.em-view.active {opacity:1;transform:translateX(0);pointer-events:auto;}

/*    LOGIN                                                   */
#view-login {display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 60px;}
.login-wrap {width:100%;max-width:400px;}
.login-eyebrow {font-size:10px;font-family:'DM Mono',monospace;color:var(--e-sage);text-transform:uppercase;letter-spacing:.14em;margin-bottom:20px;}
.login-title {font-size:26px;font-weight:700;color:var(--e-ink);letter-spacing:-.03em;line-height:1.15;margin-bottom:6px;}
.login-sub {font-size:12px;color:var(--e-ink-l);font-family:'DM Mono',monospace;margin-bottom:36px;line-height:1.7;}
.login-field {margin-bottom:14px;}
.login-label {display:block;font-size:10px;font-weight:600;color:var(--e-ink-m);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;font-family:'DM Mono',monospace;}
.login-input {width:100%;padding:13px 16px;border:1.5px solid var(--e-rule);border-radius:9px;font-size:14px;color:var(--e-ink);background:var(--e-white);font-family:'Plus Jakarta Sans',sans-serif;box-sizing:border-box;outline:none;transition:border-color .18s,box-shadow .18s;}
.login-input::placeholder {color:var(--e-ink-xl);}
.login-input:focus {border-color:var(--e-sage);box-shadow:0 0 0 3px var(--e-sage-l);}
.login-input.err {border-color:#c0392b;box-shadow:0 0 0 3px rgba(192,57,43,.08);}
.login-submit {width:100%;padding:14px 0;background:var(--e-green);color:#fff;border:none;border-radius:9px;font-size:14px;font-weight:600;font-family:'Plus Jakarta Sans',sans-serif;cursor:pointer;margin-top:6px;transition:background .18s,box-shadow .18s,transform .12s;letter-spacing:-.01em;}
.login-submit:hover {background:var(--e-mid);box-shadow:0 6px 20px rgba(26,74,46,.28);transform:translateY(-1px);}
.login-submit:active {transform:translateY(0);}
.login-submit:disabled {opacity:.65;cursor:not-allowed;transform:none;}
.login-hint {font-size:10px;font-family:'DM Mono',monospace;color:var(--e-ink-xl);text-align:center;margin-top:20px;line-height:1.6;}
.login-err {font-size:11px;color:#c0392b;font-family:'DM Mono',monospace;margin-top:10px;padding:9px 13px;border-radius:7px;background:rgba(192,57,43,.07);display:none;}
.login-err.show {display:block;}

/*    ACCESS VIEW: system topology map                       */
#view-access {display:flex;flex-direction:column;overflow:hidden;}

/*                                                            
   VIEW-ACCESS   card row layout
                                                               */

#view-access {
  display:flex; flex-direction:column; background:var(--e-parchment); overflow-y:auto;
}

/* Header */

/*                                                                    
   ORG GRAPH ACCESS VIEW   v4
                                                                       */
#view-access {
  display:flex; flex-direction:column; background:var(--e-parchment);
  overflow-y:auto; overflow-x:hidden;
}

/* Header strip */
.vax-header {
  flex-shrink:0; padding:18px 32px 14px;
  border-bottom:1px solid var(--e-rule);
  background:var(--e-white);
  display:flex; align-items:center; justify-content:space-between;
}
.vax-title { font-size:13px; font-weight:700; color:var(--e-ink); letter-spacing:-.01em; }
.vax-sub   { font-size:10px; font-family:'DM Mono',monospace; color:var(--e-ink-l); margin-top:2px; }
.vax-user-pill {
  display:flex; align-items:center; gap:7px;
  padding:5px 12px; background:var(--e-white);
  border:1px solid var(--e-rule); border-radius:20px;
  font-size:10px; font-family:'DM Mono',monospace; color:var(--e-ink-m);
  box-shadow:var(--e-s1);
}
.vax-user-dot { width:6px; height:6px; border-radius:50%; background:var(--e-sage); }

/*    GRAPH CANVAS                                          */
.vax-graph-wrap {
  position:relative; flex:1; min-height:480px; max-height:520px;
  overflow:hidden; background:var(--e-parchment);
}
#vax-svg-graph {
  position:absolute; inset:0; width:100%; height:100%;
  pointer-events:none;
}
#vax-nodes-layer {
  position:absolute; inset:0;
}

/* Department node */
.vax-node {
  position:absolute; transform:translate(-50%,-50%);
  display:flex; flex-direction:column; align-items:center;
  cursor:pointer; transition:transform .28s cubic-bezier(.34,1.56,.64,1);
  user-select:none;
}
.vax-node:hover .vax-node-card { transform:scale(1.05); }
.vax-node-card {
  border-radius:12px; padding:14px 16px;
  transition:transform .22s cubic-bezier(.34,1.56,.64,1),
             box-shadow .22s ease;
  position:relative; overflow:hidden;
  background:var(--e-white);
  border:1px solid var(--e-rule);
  box-shadow:0 2px 10px rgba(0,0,0,.06), 0 1px 3px rgba(0,0,0,.05);
  min-width:148px; max-width:175px;
}
.vax-node-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  border-radius:12px 12px 0 0; background:var(--node-accent,transparent);
}
.vax-node.restricted .vax-node-card {
  background:var(--e-paper); opacity:.5;
  box-shadow:none; cursor:default;
}
.vax-node.primary .vax-node-card {
  background:var(--e-green);
  border-color:var(--e-green);
  box-shadow:0 0 0 3px rgba(74,155,107,.2),
             0 8px 32px rgba(26,74,46,.25),
             0 2px 8px rgba(0,0,0,.1);
  min-width:178px; padding:18px 20px;
}
.vax-node.primary:hover .vax-node-card {
  transform:scale(1.03);
  box-shadow:0 0 0 4px rgba(74,155,107,.3),
             0 12px 40px rgba(26,74,46,.3),
             0 2px 8px rgba(0,0,0,.1);
}
/* Glow ring under primary */
.vax-node.primary::after {
  content:''; position:absolute; inset:-12px; border-radius:24px;
  background:radial-gradient(circle, rgba(74,155,107,.18) 0%, transparent 70%);
  pointer-events:none; z-index:-1;
  animation:graphGlow 3s ease-in-out infinite;
}
@keyframes graphGlow {
  0%,100%{opacity:.6;} 50%{opacity:1;}
}
.vax-node.active .vax-node-card {
  box-shadow:0 0 0 2px var(--e-sage),
             0 6px 24px rgba(0,0,0,.1);
  transform:scale(1.04);
}

/* Node internals */
.vax-node-seq {
  font-size:8px; font-family:'DM Mono',monospace;
  color:var(--e-ink-xl); letter-spacing:.08em; margin-bottom:6px;
}
.vax-node.primary .vax-node-seq { color:rgba(255,255,255,.45); }
.vax-node.restricted .vax-node-seq { color:var(--e-ink-xl); }

.vax-node-name {
  font-size:13px; font-weight:700; color:var(--e-ink);
  letter-spacing:-.015em; margin-bottom:2px;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  max-width:150px;
}
.vax-node.primary .vax-node-name { font-size:15px; color:#fff; }
.vax-node.restricted .vax-node-name { color:var(--e-ink-l); }

.vax-node-kpis {
  display:flex; flex-direction:column; gap:4px;
  margin-top:8px;
}
.vax-node-kpi {
  display:flex; justify-content:space-between; align-items:baseline;
  font-size:9px; font-family:'DM Mono',monospace;
}
.vax-node-klbl { color:var(--e-ink-l); }
.vax-node-kval { font-weight:700; }
.vax-node-kval.good { color:#1a5c32; }
.vax-node-kval.warn { color:#b7770d; }
.vax-node-kval.bad  { color:#c0392b; }
.vax-node.primary .vax-node-klbl { color:rgba(255,255,255,.5); }
.vax-node.primary .vax-node-kval { color:rgba(255,255,255,.92); }

.vax-node-badge {
  margin-top:9px; padding-top:7px; border-top:1px solid rgba(0,0,0,.06);
  font-size:8px; font-family:'DM Mono',monospace;
  color:var(--e-ink-xl); display:flex; align-items:center; gap:5px;
}
.vax-node.primary .vax-node-badge {
  border-top-color:rgba(255,255,255,.15); color:rgba(255,255,255,.55);
}
.vax-node-bdot { width:5px; height:5px; border-radius:50%; flex-shrink:0; }

/* SVG edge labels */
.edge-label {
  font-size:9px; font-family:'DM Mono',monospace;
  fill:var(--label-color,#7a9585);
  filter:drop-shadow(0 1px 2px rgba(255,255,255,.9));
}

/* Legend */
.vax-legend-bar {
  display:flex; align-items:center; gap:18px; flex-wrap:wrap;
  padding:10px 32px; border-top:1px solid var(--e-rule);
  background:var(--e-white); flex-shrink:0;
}
.vax-leg {
  display:flex; align-items:center; gap:5px;
  font-size:8px; font-family:'DM Mono',monospace; color:var(--e-ink-l);
}
.vax-leg-dot { width:8px; height:8px; border-radius:2px; }
.vax-leg-green { background:var(--e-green); }
.vax-leg-sage  { background:var(--e-sage); }
.vax-leg-grey  { background:var(--e-ink-xl); }
.vax-leg-red   { background:#c0392b; }
.vax-leg-amber { background:#b7770d; }
.vax-leg-line-green { width:20px; height:2px; background:#4a9b6b; border-radius:1px; }
.vax-leg-line-red   { width:20px; height:2px; background:#c0392b; border-radius:1px; }
.vax-leg-line-amber { width:20px; height:2px; background:#b7770d; border-radius:1px; }

/*    DETAIL PANEL                                         */
.vax-detail-panel {
  flex-shrink:0; padding:0 32px 28px; overflow:hidden;
  opacity:0; transform:translateY(10px);
  transition:opacity .3s ease, transform .3s ease;
  pointer-events:none;
}
.vax-detail-panel.visible {
  opacity:1; transform:translateY(0); pointer-events:auto;
}
.vax-detail-inner {
  background:var(--e-white); border:1px solid var(--e-rule);
  border-radius:12px; overflow:hidden;
  box-shadow:0 4px 24px rgba(0,0,0,.07), 0 1px 4px rgba(0,0,0,.04);
}

/* Detail header */
.vax-det-header {
  display:flex; align-items:center; gap:0;
  padding:16px 24px; border-bottom:1px solid var(--e-rule);
  background:linear-gradient(135deg, rgba(26,74,46,.04) 0%, transparent 100%);
}
.vax-det-name {
  font-size:18px; font-weight:700; color:var(--e-green);
  letter-spacing:-.025em; margin-right:28px; flex-shrink:0;
}
.vax-det-kpis { display:flex; flex:1; gap:0; }
.vax-det-kpi  {
  flex:1; display:flex; flex-direction:column; gap:2px;
  padding:0 18px; border-right:1px solid var(--e-rule);
}
.vax-det-kpi:first-child { padding-left:0; }
.vax-det-kpi:last-child  { border-right:none; }
.vax-det-klbl {
  font-size:8px; font-family:'DM Mono',monospace;
  color:var(--e-ink-xl); text-transform:uppercase; letter-spacing:.1em;
}
.vax-det-kval {
  font-size:17px; font-weight:700; letter-spacing:-.03em; margin-top:1px;
}
.vax-det-kval.good { color:#1a5c32; }
.vax-det-kval.warn { color:#b7770d; }
.vax-det-kval.bad  { color:#c0392b; }
.vax-det-ktrend {
  font-size:8px; font-family:'DM Mono',monospace;
  color:var(--e-ink-xl); margin-top:2px;
}

/* Detail body   3 columns */
.vax-det-body {
  display:grid; grid-template-columns:1fr 1fr 1fr;
}
.vax-det-col {
  padding:16px 20px; border-right:1px solid var(--e-rule);
}
.vax-det-col:last-child { border-right:none; }
.vax-det-col-title {
  font-size:8px; font-family:'DM Mono',monospace;
  color:var(--e-ink-xl); text-transform:uppercase; letter-spacing:.12em;
  margin-bottom:10px; font-weight:600;
}
.vax-det-row {
  display:flex; align-items:flex-start; gap:8px;
  padding:6px 0; border-bottom:1px solid var(--e-rule);
}
.vax-det-row:last-child { border-bottom:none; }
.vax-det-badge {
  font-size:8px; font-family:'DM Mono',monospace; font-weight:700;
  padding:2px 6px; border-radius:3px; white-space:nowrap; flex-shrink:0;
}
.vax-det-arrow { font-size:10px; color:var(--e-ink-xl); flex-shrink:0; }
.vax-det-desc  { font-size:10px; color:var(--e-ink-m); flex:1; line-height:1.5; }
.vax-det-pill  {
  font-size:8px; font-family:'DM Mono',monospace;
  padding:2px 7px; border-radius:3px; white-space:nowrap; flex-shrink:0;
}
.vax-det-pill.bad  { background:rgba(192,57,43,.08); color:#8b1c13; }
.vax-det-pill.warn { background:rgba(183,119,13,.08); color:#7a5200; }
.vax-det-pill.good { background:rgba(26,92,50,.08);  color:#1a5c32; }

/* Insights col */
.vax-det-insight {
  display:flex; gap:8px; padding:6px 0; border-bottom:1px solid var(--e-rule);
}
.vax-det-insight:last-child { border-bottom:none; }
.vax-det-insight-dot {
  width:7px; height:7px; border-radius:50%; flex-shrink:0; margin-top:3px;
}
.vax-det-insight-text {
  font-size:10px; color:var(--e-ink-m); line-height:1.55; flex:1;
}
.vax-det-insight-tag {
  font-size:8px; font-family:'DM Mono',monospace;
  padding:1px 5px; border-radius:2px; flex-shrink:0; margin-top:2px;
}

/* Footer */
.vax-det-footer {
  display:flex; align-items:center; gap:16px;
  padding:12px 20px; border-top:1px solid var(--e-rule);
  background:var(--e-paper);
}
.vax-det-insight-main {
  flex:1; font-size:11px; color:var(--e-ink-m); line-height:1.6;
  font-style:italic; padding-left:10px;
  border-left:2px solid var(--e-sage);
}
.vax-det-cta {
  flex-shrink:0; padding:10px 22px;
  background:var(--e-green); color:#fff; border:none;
  border-radius:7px; font-size:12px; font-weight:600;
  font-family:'Plus Jakarta Sans',sans-serif; cursor:pointer;
  transition:background .15s, box-shadow .15s, transform .12s;
}
.vax-det-cta:hover {
  background:var(--e-mid);
  box-shadow:0 5px 18px rgba(26,74,46,.28);
  transform:translateY(-1px);
}

/* Hidden compat elements */
#vax-canvas, #access-dept-grid, #acc-granted-lbl { display:none !important; }

/*    INTEL VIEW: process map + flow                         */
#view-intel {display:flex;flex-direction:column;overflow:hidden;}
.vi2-header {
  flex-shrink:0; padding:16px 32px;
  background:var(--e-white); border-bottom:1px solid var(--e-rule);
  display:flex; align-items:center; gap:14px;
}
.vi2-back {
  background:none; border:1px solid var(--e-rule); border-radius:6px;
  padding:7px 13px; font-size:10px; font-family:'DM Mono',monospace;
  color:var(--e-ink-l); cursor:pointer; transition:border-color .14s,color .14s; flex-shrink:0;
}
.vi2-back:hover {border-color:var(--e-sage);color:var(--e-green);}
.vi2-dept-name {font-size:20px;font-weight:700;color:var(--e-green);letter-spacing:-.035em;}
.vi2-dept-sub  {font-size:10px;color:var(--e-ink-m);font-family:'DM Mono',monospace;margin-top:2px;}
.vi2-enter {
  margin-left:auto; background:var(--e-green); color:#fff; border:none;
  border-radius:7px; padding:10px 20px; font-size:12px; font-weight:600;
  font-family:'Plus Jakarta Sans',sans-serif; cursor:pointer;
  transition:background .15s,box-shadow .15s,transform .12s;
}
.vi2-enter:hover {background:var(--e-mid);box-shadow:0 5px 18px rgba(26,74,46,.28);transform:translateY(-1px);}
.vi2-enter:disabled {opacity:.65;cursor:not-allowed;transform:none;}
/* Split: left SVG relationship map + right process flow */
.vi2-body {flex:1;display:flex;overflow:hidden;}
#vi2-map   {flex:0 0 52%;border-right:1px solid var(--e-rule);overflow:hidden;}
#vi2-flow  {flex:1;overflow-y:auto;padding:20px 28px 40px;background:var(--e-parchment);}

/* Process flow stages (right side) */
.pf-kpi-line {
  display:flex; gap:0; margin-bottom:20px;
  border-bottom:1px solid var(--e-rule); padding-bottom:14px;
}
.pf-kpi {
  flex:1; display:flex; flex-direction:column; gap:2px;
  padding:0 16px; border-right:1px solid var(--e-rule);
}
.pf-kpi:first-child {padding-left:0;}
.pf-kpi:last-child  {border-right:none;}
.pf-kpi-lbl {font-size:9px;font-family:'DM Mono',monospace;color:var(--e-ink-xl);text-transform:uppercase;letter-spacing:.08em;}
.pf-kpi-val {font-size:18px;font-weight:700;letter-spacing:-.04em;line-height:1.1;}
.pf-kpi-val.good {color:var(--e-sage);}
.pf-kpi-val.warn {color:#b7770d;}
.pf-kpi-val.bad  {color:#c0392b;}
.pf-kpi-trend {font-size:9px;font-family:'DM Mono',monospace;}
.pf-kpi-trend.good {color:#1a5c32;}
.pf-kpi-trend.warn {color:#7a5200;}
.pf-kpi-trend.bad  {color:#8b1c13;}

/* Flow stage */
.pf-sec-lbl {font-size:9px;font-family:'DM Mono',monospace;color:var(--e-ink-xl);text-transform:uppercase;letter-spacing:.12em;margin-bottom:12px;display:flex;align-items:center;gap:10px;}
.pf-sec-lbl::after {content:'';flex:1;height:1px;background:var(--e-rule);}
.pf-stage {display:flex;align-items:stretch;gap:12px;padding:0 0 2px;}
.pf-stage-connector {display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:16px;}
.pf-stage-dot {width:9px;height:9px;border-radius:50%;flex-shrink:0;border:2px solid;margin-top:2px;}
.pf-stage-line {flex:1;width:1px;min-height:14px;margin-top:2px;}
.pf-stage:last-child .pf-stage-line {display:none;}
.pf-stage-body {flex:1;display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,.04);}
.pf-stage:last-child .pf-stage-body {border-bottom:none;}
.pf-stage-name {font-size:11px;font-weight:600;color:var(--e-ink);min-width:130px;flex-shrink:0;}
.pf-stage-bar  {flex:1;height:4px;background:rgba(0,0,0,.06);border-radius:2px;overflow:hidden;}
.pf-stage-fill {height:100%;border-radius:2px;transition:width .5s var(--ease-out);}
.pf-stage-time {font-size:11px;font-weight:700;font-family:'DM Mono',monospace;flex-shrink:0;width:38px;text-align:right;}
.pf-stage-tag  {font-size:8px;font-family:'DM Mono',monospace;padding:2px 6px;border-radius:3px;white-space:nowrap;flex-shrink:0;}
.pf-stage-tag.slow {background:rgba(192,57,43,.09);color:#8b1c13;}
.pf-stage-tag.mod  {background:rgba(183,119,13,.08);color:#7a5200;}
.pf-stage-tag.fast {background:rgba(74,155,107,.1);color:#1a5c32;}

/* Health inline */
.pf-health-row {display:flex;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid rgba(0,0,0,.04);}
.pf-health-row:last-child {border-bottom:none;}
.pf-health-dot {width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:3px;}
.pf-health-level {font-size:9px;font-family:'DM Mono',monospace;font-weight:700;text-transform:uppercase;letter-spacing:.06em;flex-shrink:0;width:62px;}
.pf-health-level.critical {color:#c0392b;}
.pf-health-level.warning  {color:#b7770d;}
.pf-health-level.notice   {color:#7a9585;}
.pf-health-text  {font-size:11px;color:var(--e-ink-m);flex:1;line-height:1.45;}
.pf-health-chip  {font-size:8px;font-family:'DM Mono',monospace;padding:2px 7px;border-radius:10px;white-space:nowrap;flex-shrink:0;font-weight:600;}

/*    Keyframes                                               */
@keyframes splashIn {from{opacity:0;transform:scale(.93) translateY(16px)}to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes fadeUp   {from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes dotPulse {0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.5)}}
@keyframes ringPulse{0%,100%{opacity:.6}50%{opacity:.14}}
