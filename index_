  A.acts.forEach(function(a){if(!bSet[a])dh+='<div class="diff-item missing">Only in A: "'+a+'"</div>';});
  B.acts.forEach(function(b){if(!aSet[b])dh+='<div class="diff-item extra">Only in B: "'+b+'"</div>';});
