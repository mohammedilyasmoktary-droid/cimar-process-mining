}
.org-dept-card.primary:hover { transform:translateY(-3px); box-shadow:0 0 0 3px rgba(45,155,94,.28), 0 10px 32px rgba(14,74,40,.42), inset 0 1px 0 rgba(255,255,255,.12); }

/* FIX 3: Director mode   all depts equal medium green */
.org-dept-card.director-dept {
  background:linear-gradient(160deg,#1a5e36 0%,#236e42 100%);
