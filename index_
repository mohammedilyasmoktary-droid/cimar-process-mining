  var actHtml='<table style="width:100%;border-collapse:collapse;font-size:12px"><thead><tr>'
    +'<th style="text-align:left;padding:8px;border-bottom:1px solid var(--border);font-size:10px;color:var(--textd);text-transform:uppercase">Activity</th>'
    +'<th style="text-align:right;padding:8px;border-bottom:1px solid var(--border);font-size:10px;color:#22883f;text-transform:uppercase">A avg</th>'
