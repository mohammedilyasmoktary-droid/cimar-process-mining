// -- CSV UPLOAD ----------------------------------------------------------------
function uniq(arr){var s={},o=[];for(var i=0;i<arr.length;i++){if(!s[arr[i]]){s[arr[i]]=1;o.push(arr[i]);}}return o;}
function safeParse(s){
  if(!s)return new Date(NaN);
  var p=s.trim().replace('T',' ').split(/[\s:\-]/);
  if(p.length>=6)return new Date(parseInt(p[0]),parseInt(p[1])-1,parseInt(p[2]),parseInt(p[3]),parseInt(p[4]),parseInt(p[5]));
  return new Date(s);
}
function doUpload(input){
  var f=input.files[0];if(!f)return;
  var msg=document.getElementById('up-msg');
  msg.style.display='block';msg.style.background='rgba(0,78,43,.08)';msg.style.color='#004e2b';
  msg.textContent='Reading CSV...';
  var reader=new FileReader();
  reader.onload=function(e){
    try{
      var txt=e.target.result;
      var lines=txt.trim().split('\n');
      if(lines.length<2)throw new Error('CSV appears empty');
      var hdr=lines[0].split(',').map(function(h){return h.trim().replace(/^"|"$/g,'');});
      var ci=hdr.indexOf('case_id'),ai=hdr.indexOf('activity'),ti=hdr.indexOf('timestamp');
      var ri=hdr.indexOf('resource'),pi=hdr.indexOf('plant'),si2=hdr.indexOf('status');
      if(ci<0||ai<0||ti<0)throw new Error('Missing columns: case_id, activity, timestamp');
      var rows=[];
      for(var i=1;i<lines.length;i++){
        var l=lines[i].trim();if(!l)continue;
        var cols=l.split(',').map(function(x){return x.trim().replace(/^"|"$/g,'');});
        var ts=safeParse(cols[ti]||'');
        if(cols[ci]&&cols[ai]&&!isNaN(ts.getTime())&&ts.getTime()>0){
          rows.push({case_id:cols[ci],activity:cols[ai],timestamp:ts,
            resource:ri>=0?(cols[ri]||'Unknown'):'Unknown',
            plant:pi>=0?(cols[pi]||'Unknown'):'Unknown',
            status:si2>=0?(cols[si2]||'done'):'done'});
        }
      }
      window._rawRows=rows;
      if(!rows.length)throw new Error('No valid rows found - check timestamp format (YYYY-MM-DD HH:MM:SS)');
      rows.sort(function(a,b){return a.timestamp-b.timestamp;});
      var cases=uniq(rows.map(function(r){return r.case_id;}));
      var plants=uniq(rows.map(function(r){return r.plant;}));
      var activities=uniq(rows.map(function(r){return r.activity;}));
      msg.textContent='Analysing '+cases.length+' cases . '+activities.length+' activities...';

      setTimeout(function(){
        try{
          // -- GROUP BY CASE ----------------------------------------------
          var byCase={};
          rows.forEach(function(r){
            if(!byCase[r.case_id])byCase[r.case_id]=[];
            byCase[r.case_id].push(r);
          });

          // -- CYCLE TIMES ------------------------------------------------
          var caseDurs={};
          cases.forEach(function(cid){
            var cr=byCase[cid];
            var ts=cr.map(function(r){return r.timestamp.getTime();});
            caseDurs[cid]=(Math.max.apply(null,ts)-Math.min.apply(null,ts))/3600000;
          });
          var durs=cases.map(function(cid){return caseDurs[cid];});
          durs.sort(function(a,b){return a-b;});
          var avgCycle=durs.reduce(function(s,v){return s+v;},0)/durs.length;
          var p90=durs[Math.min(Math.floor(durs.length*.9),durs.length-1)]||0;
          var maxDur=durs[durs.length-1]||0;

          // -- ACTIVITY WAIT TIMES ----------------------------------------
          var actWaits={};
          var actCounts={};
          cases.forEach(function(cid){
            var cr=byCase[cid].slice().sort(function(a,b){return a.timestamp-b.timestamp;});
            cr.forEach(function(r){actCounts[r.activity]=(actCounts[r.activity]||0)+1;});
            for(var i=0;i<cr.length-1;i++){
              var act=cr[i].activity;
              var wait=(cr[i+1].timestamp.getTime()-cr[i].timestamp.getTime())/60000;
              if(wait>=0){
                if(!actWaits[act])actWaits[act]=[];
                actWaits[act].push(wait);
              }
            }
          });

          // Build activity stats sorted by avg wait desc
          var actStats=activities.map(function(a){
            var waits=actWaits[a]||[];
            waits.sort(function(x,y){return x-y;});
            var avg=waits.length?waits.reduce(function(s,v){return s+v;},0)/waits.length:0;
            var p90w=waits.length?waits[Math.floor(waits.length*.9)]||0:0;
            var mx=waits.length?waits[waits.length-1]:0;
            var col=avg>90?'#c0392b':avg>30?'#b7770d':'#22883f';
            return{a:a,cnt:actCounts[a]||0,avg:parseFloat(avg.toFixed(1)),p90:parseFloat(p90w.toFixed(1)),max:parseFloat(mx.toFixed(1)),col:col};
          });
          actStats.sort(function(a,b){return b.avg-a.avg;});

          // -- REWORK DETECTION -------------------------------------------
          // Detect repeated activities = rework
          var reworkKeywords=['retest','reject','rework','redo','re-','failed','repeat','resubmit'];
          var reworkActs=activities.filter(function(a){
            var al=a.toLowerCase();
            return reworkKeywords.some(function(kw){return al.indexOf(kw)>=0;});
          });
          var reworkCases=cases.filter(function(cid){
            return byCase[cid].some(function(r){
              return reworkActs.indexOf(r.activity)>=0;
            });
          });
          var reworkRate=reworkCases.length/cases.length*100;

          // -- PLANT STATS ------------------------------------------------
          var plantStats=plants.map(function(p){
            var pcases=cases.filter(function(cid){return byCase[cid][0].plant===p;});
            var pdurs=pcases.map(function(cid){return caseDurs[cid];});
            var pavg=pdurs.length?pdurs.reduce(function(s,v){return s+v;},0)/pdurs.length:0;
            var prw=pcases.filter(function(cid){
              return byCase[cid].some(function(r){return reworkActs.indexOf(r.activity)>=0;});
            }).length;
            return{p:p,cnt:pcases.length,hrs:parseFloat(pavg.toFixed(2)),rw:parseFloat((prw/pcases.length*100).toFixed(1))};
          }).sort(function(a,b){return a.hrs-b.hrs;});

          // -- REWORK BY PLANT --------------------------------------------
          var rwByPlant=plantStats.map(function(p){
            var pcases=cases.filter(function(cid){return byCase[cid][0].plant===p.p;});
            var prw=pcases.filter(function(cid){return byCase[cid].some(function(r){return reworkActs.indexOf(r.activity)>=0;});}).length;
            return{p:p.p,rw:prw,tot:pcases.length,pct:parseFloat((prw/pcases.length*100).toFixed(1))};
          }).sort(function(a,b){return b.pct-a.pct;});

          // -- DURATION DISTRIBUTION --------------------------------------
          var bkts={'<2h':0,'2-4h':0,'4-6h':0,'6-8h':0,'8-12h':0,'12-24h':0,'>24h':0};
          durs.forEach(function(h){
            if(h<2)bkts['<2h']++;else if(h<4)bkts['2-4h']++;else if(h<6)bkts['4-6h']++;
            else if(h<8)bkts['6-8h']++;else if(h<12)bkts['8-12h']++;else if(h<24)bkts['12-24h']++;else bkts['>24h']++;
          });

          // -- SLOWEST CASES ----------------------------------------------
          var slowest=cases.slice().sort(function(a,b){return caseDurs[b]-caseDurs[a];}).slice(0,8).map(function(cid){
            var cr=byCase[cid];
            return{id:cid,h:parseFloat(caseDurs[cid].toFixed(1)),p:cr[0].plant,e:cr.length,
              r:cr.some(function(r){return reworkActs.indexOf(r.activity)>=0;})};
          });

          // -- DIRECTLY-FOLLOWS GRAPH -------------------------------------
          var edgeMap={};
          var edgeTime={};
          cases.forEach(function(cid){
            var cr=byCase[cid].slice().sort(function(a,b){return a.timestamp-b.timestamp;});
            for(var i=0;i<cr.length-1;i++){
              var key=cr[i].activity+'|||'+cr[i+1].activity;
              edgeMap[key]=(edgeMap[key]||0)+1;
              if(!edgeTime[key])edgeTime[key]=[];
              edgeTime[key].push((cr[i+1].timestamp.getTime()-cr[i].timestamp.getTime())/60000);
            }
          });
          var newEdges=Object.keys(edgeMap).map(function(k){
            var parts=k.split('|||');
            var times=edgeTime[k];
            var avg=times.reduce(function(s,v){return s+v;},0)/times.length;
            return{f:parts[0],t:parts[1],c:edgeMap[k],avg:parseFloat(avg.toFixed(1))};
          }).sort(function(a,b){return b.c-a.c;}).slice(0,15);

          // -- PROCESS VARIANTS -------------------------------------------
          var varMap={};
          cases.forEach(function(cid){
            var seq=byCase[cid].slice().sort(function(a,b){return a.timestamp-b.timestamp;}).map(function(r){return r.activity;}).join('->');
            varMap[seq]=(varMap[seq]||0)+1;
          });
          var newVariants=Object.keys(varMap).sort(function(a,b){return varMap[b]-varMap[a];}).slice(0,6).map(function(v){
            var steps=v.split('->');
            var hasRework=steps.some(function(s){var sl=s.toLowerCase();return reworkKeywords.some(function(kw){return sl.indexOf(kw)>=0;});});
            var vcases=cases.filter(function(cid){
              var seq=byCase[cid].slice().sort(function(a,b){return a.timestamp-b.timestamp;}).map(function(r){return r.activity;}).join('->');
              return seq===v;
            });
            var vdurs=vcases.map(function(cid){return caseDurs[cid];});
            var vavg=vdurs.length?vdurs.reduce(function(s,x){return s+x;},0)/vdurs.length:avgCycle;
            var dispSteps=steps.length>7?steps.slice(0,3).concat(['...']).concat(steps.slice(-2)):steps;
            return{v:dispSteps,
              c:varMap[v],p:parseFloat((varMap[v]/cases.length*100).toFixed(1)),s:steps.length,r:hasRework,avgH:parseFloat(vavg.toFixed(1))};
          });

          // -- HEATMAP DATA -----------------------------------------------
          var topActs=actStats.slice(0,7).map(function(a){return a.a;});
          var hmAvg=topActs.map(function(act){
            return plants.map(function(p){
              var prows=rows.filter(function(r){return r.plant===p;});
              var pByCase={};
              prows.forEach(function(r){if(!pByCase[r.case_id])pByCase[r.case_id]=[];pByCase[r.case_id].push(r);});
              var waits=[];
              Object.keys(pByCase).forEach(function(cid){
                var cr=pByCase[cid].slice().sort(function(a,b){return a.timestamp-b.timestamp;});
                for(var i=0;i<cr.length-1;i++){
                  if(cr[i].activity===act){waits.push((cr[i+1].timestamp.getTime()-cr[i].timestamp.getTime())/60000);}
                }
              });
              return waits.length?parseFloat((waits.reduce(function(s,v){return s+v;},0)/waits.length).toFixed(0)):0;
            });
          });

          // -- RECOMMENDATIONS --------------------------------------------
          var newRecs=[];
          var topBN=actStats[0];
          if(topBN&&topBN.avg/60>1.5){
            newRecs.push({id:'REC-001',s:topBN.avg/60>4?'critical':'warning',cat:'Bottleneck',
              title:'Bottleneck Detected: '+topBN.a,
              issue:topBN.a+' averages '+Math.round(topBN.avg)+'m wait (P90: '+Math.round(topBN.p90)+'m).',
              cause:'High workload, manual handoffs, or missing automation at this stage.',
              action:'1. Assign dedicated resource. 2. Set SLA alerts. 3. Review handoff process.',
              impact:'Reducing wait by 50% saves ~'+(topBN.avg/60/2).toFixed(1)+'h per case.'});
          }
          if(reworkRate>10){
            newRecs.push({id:'REC-002',s:reworkRate>20?'critical':'warning',cat:'Quality',
              title:'High Rework / Rejection Rate',
              issue:reworkRate.toFixed(1)+'% of cases contain a rework or rejection step.',
              cause:'Inconsistent process execution, insufficient checks, or unclear criteria.',
              action:'1. Audit rework triggers. 2. Add pre-step quality gates. 3. Train resources.',
              impact:'Eliminating rework for '+reworkCases.length+' cases saves significant cycle time.'});
          }
          var netAvg=avgCycle;
          plantStats.forEach(function(p){
            if(p.hrs>netAvg*1.35&&p.cnt>=5){
              newRecs.push({id:'REC-P-'+p.p.slice(0,3).toUpperCase(),s:'warning',cat:'Plant Performance',
                title:'Site Underperformance: '+p.p,
                issue:p.p+' averages '+p.hrs.toFixed(1)+'h - '+(p.hrs/netAvg).toFixed(1)+'x network average.',
                cause:'Local staffing, equipment, or process issues specific to this site.',
                action:'1. Benchmark against '+plantStats[0].p+' (fastest: '+plantStats[0].hrs.toFixed(1)+'h). 2. Site audit. 3. Resource review.',
                impact:'Aligning to network avg saves ~'+(p.hrs-netAvg).toFixed(1)+'h per case at '+p.p+'.'});
            }
          });
          if(newRecs.length===0){
            newRecs.push({id:'REC-OK',s:'info',cat:'Status',title:'Process Within Normal Range',
              issue:'No critical bottlenecks or rework issues detected in this dataset.',
              cause:'Processes appear to be running within acceptable parameters.',
              action:'Continue monitoring. Upload more recent data for ongoing tracking.',
              impact:'Maintain current performance levels.'});
          }

          // -- UPDATE GLOBAL D --------------------------------------------
          D.acts=actStats;
          D.bns=actStats.slice(0,5);
          D.plants=plantStats;
          D.rw_plants=rwByPlant;
          D.dur={l:Object.keys(bkts),v:Object.values(bkts)};
          D.slow=slowest;
          D.edges=newEdges;
          D.variants=newVariants;
          selVariant=0;
          D.recs=newRecs;
          D.heatmapData={activities:topActs,plants:plants,avg:hmAvg,p90:hmAvg.map(function(r){return r.map(function(v){return Math.round(v*1.6);});})};
          D.hm={acts:topActs,plants:plants,avg:hmAvg,p90:hmAvg.map(function(r){return r.map(function(v){return Math.round(v*1.6);});})};
          D.sparkData={cases:[cases.length],cycle:[parseFloat(avgCycle.toFixed(1))],rework:[parseFloat(reworkRate.toFixed(1))],approval:[approvalStat?(approvalStat.avg/60):(0)]};

          // -- UPDATE ALL UI ELEMENTS -------------------------------------
          var bottleneck=actStats[0]?actStats[0].a.split(' ')[0]:'-';
          // Ticker bar
          // Update sidebar
          var ssIds=['ss-cases','ss-cycle','ss-rework','ss-max','ss-clean'];
          var ssTot=cases.length;
          var ssRwC=Math.round(ssTot*reworkRate/100);
          var ssVals=[ssTot.toLocaleString(),avgCycle.toFixed(1)+'h',reworkRate.toFixed(1)+'%',maxDur.toFixed(1)+'h',((ssTot-ssRwC)/ssTot*100).toFixed(1)+'%'];
          ssIds.forEach(function(id,i){var el=document.getElementById(id);if(el)el.textContent=ssVals[i];});
          var tkIds=['tk-cases','tk-cycle','tk-rework','tk-bn','tk-p90'];
          var tkVals=[cases.length.toLocaleString(),avgCycle.toFixed(1)+'h',(reworkRate).toFixed(1)+'%',bottleneck,p90.toFixed(1)+'h'];
          tkIds.forEach(function(id,i){var el=document.getElementById(id);if(el)el.textContent=tkVals[i];});

          // KPI cards
          var kpiIds=['kpi-cases','kpi-cycle','kpi-rework','kpi-approval'];
          var approvalStat=actStats.find(function(a){return a.a.toLowerCase().indexOf('approv')>=0;});
          var kpiVals=[cases.length.toLocaleString(),avgCycle.toFixed(1)+'h',reworkRate.toFixed(1)+'%',approvalStat?(approvalStat.avg/60).toFixed(1)+'h':'-'];
          kpiIds.forEach(function(id,i){var el=document.getElementById(id);if(el)el.textContent=kpiVals[i];});

          // Sidebar metrics
          var ssIds=['ss-cases','ss-cycle','ss-rework','ss-max','ss-clean'];
          var ssVals=[cases.length.toLocaleString(),avgCycle.toFixed(1)+'h',reworkRate.toFixed(1)+'%',maxDur.toFixed(1)+'h',((cases.length-reworkCases.length)/cases.length*100).toFixed(1)+'%'];
          ssIds.forEach(function(id,i){var el=document.getElementById(id);if(el)el.textContent=ssVals[i];});

          // Alert strip
          var alApproval=document.getElementById('al-approval');
          var alRework=document.getElementById('al-rework');
          if(alApproval&&approvalStat)alApproval.textContent=(approvalStat.avg/60).toFixed(1)+'h avg';
          if(alRework)alRework.textContent=reworkRate.toFixed(1)+'%';
          var slowestPlant=plantStats[plantStats.length-1];
          var alPlant=document.getElementById('al-plant');
          if(alPlant&&slowestPlant)alPlant.textContent=slowestPlant.hrs.toFixed(1)+'h avg';

