}

function renderCrossInsights(A, B){
  var el=document.getElementById('cmp-cross-insights');if(!el)return;
  var insights=[];
  // Cycle time winner
  if(Math.abs(A.avg-B.avg)>0.5){
    var faster=A.avg<B.avg?'A':'B';
    var slower=faster==='A'?'B':'A';
    var diff=Math.abs(A.avg-B.avg).toFixed(1);
    insights.push({col:'#22883f',text:'Process '+faster+' is '+diff+'h faster on average than Process '+slower+'. Investigate what Process '+faster+' does differently at the bottleneck stage.'});
  }
  // Rework comparison
  var rwDiff=Math.abs(A.rw-B.rw);
  if(rwDiff>5){
    var betterRw=A.rw<B.rw?'A':'B';
    var worseRw=betterRw==='A'?'B':'A';
    insights.push({col:'#22883f',text:'Process '+betterRw+' has '+rwDiff.toFixed(1)+'pp lower rework rate. Apply its quality controls to Process '+worseRw+'.'});
  }
  // Unique activities in each
  var aOnly=A.acts.filter(function(a){return B.acts.indexOf(a)<0;});
  var bOnly=B.acts.filter(function(b){return A.acts.indexOf(b)<0;});
  if(aOnly.length>0){insights.push({col:'#b7770d',text:'Process A has '+aOnly.length+' unique step(s) not in B: '+aOnly.slice(0,3).join(', ')+'.'});}
  if(bOnly.length>0){insights.push({col:'#b7770d',text:'Process B has '+bOnly.length+' unique step(s) not in A: '+bOnly.slice(0,3).join(', ')+'.'});}
  // Same bottleneck?
  var aActList=Object.keys(A.actStats).map(function(a){return{a:a,avg:A.actStats[a].avg};}).sort(function(x,y){return y.avg-x.avg;});
  var bActList=Object.keys(B.actStats).map(function(b){return{a:b,avg:B.actStats[b].avg};}).sort(function(x,y){return y.avg-x.avg;});
  if(aActList.length&&bActList.length&&aActList[0].a===bActList[0].a){
    insights.push({col:'#c0392b',text:'Both processes share the same bottleneck: "'+aActList[0].a+'". This is a systemic issue affecting multiple departments - prioritise fixing it.'});
  }
  if(insights.length===0){
    insights.push({col:'#8aaa8e',text:'Processes are similar in performance. No significant cross-process patterns detected.'});
  }
  var h='';
  insights.forEach(function(ins){
    h+='<div style="display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);align-items:flex-start">';
    h+='<div style="width:4px;min-height:40px;background:'+ins.col+';border-radius:2px;flex-shrink:0;margin-top:2px"></div>';
    h+='<div style="font-size:12px;color:var(--text);line-height:1.6">'+ins.text+'</div></div>';
  });
  el.innerHTML=h;
}

