// =========================================================================
// ENTRY SCREEN - render and wire
// =========================================================================
function initSplashCanvas(){
  var canvas=document.getElementById('splash-canvas');
  if(!canvas)return;
  var ctx=canvas.getContext('2d');
  var W,H,dots,raf;
  function resize(){
    W=canvas.width=canvas.offsetWidth||window.innerWidth;
    H=canvas.height=canvas.offsetHeight||window.innerHeight;
    dots=[];
    var spacing=48;
    for(var x=spacing/2;x<W;x+=spacing){
      for(var y=spacing/2;y<H;y+=spacing){
        dots.push({x:x,y:y,r:1.2,phase:Math.random()*Math.PI*2,speed:.4+Math.random()*.4});
      }
    }
  }
  var t=0;
  function draw(){
    ctx.clearRect(0,0,W,H);
    t+=.012;
    dots.forEach(function(d){
      var pulse=.5+.5*Math.sin(t*d.speed+d.phase);
      ctx.beginPath();
      ctx.arc(d.x,d.y,d.r*(.6+.4*pulse),0,Math.PI*2);
      ctx.fillStyle='rgba(255,255,255,'+(0.25+0.35*pulse)+')';
      ctx.fill();
    });
    raf=requestAnimationFrame(draw);
  }
  window.addEventListener('resize',resize);
  resize();
  draw();
  canvas._stopAnim=function(){cancelAnimationFrame(raf);};
}

