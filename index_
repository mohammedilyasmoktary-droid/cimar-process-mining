  font-family: 'DM Mono', monospace !important;
  font-weight: 700 !important;
  padding: 2px 7px !important;
  border-radius: 3px !important;
  grid-column: 3;
  grid-row: 1;
  white-space: nowrap;
  align-self: center;
}
