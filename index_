function renderBuilder(){
  var container=document.getElementById('builder-nodes');
  if(!container)return;
  container.innerHTML='';
  var svgEl=document.getElementById('builder-svg');
  if(!svgEl)return;
  svgEl.innerHTML='';

  // Arrow marker
  var ns='http://www.w3.org/2000/svg';
  var defs=document.createElementNS(ns,'defs');
  var mk=document.createElementNS(ns,'marker');
  mk.setAttribute('id','b-arrow');mk.setAttribute('viewBox','0 0 10 10');
  mk.setAttribute('refX',8);mk.setAttribute('refY',5);
  mk.setAttribute('markerWidth',6);mk.setAttribute('markerHeight',6);
  mk.setAttribute('orient','auto-start-reverse');
  var mp=document.createElementNS(ns,'path');
  mp.setAttribute('d','M2 2L8 5L2 8');mp.setAttribute('fill','none');
  mp.setAttribute('stroke','#5eac2c');mp.setAttribute('stroke-width','1.5');
  mk.appendChild(mp);defs.appendChild(mk);svgEl.appendChild(defs);

  // Draw edges
  builderEdges.forEach(function(e){
    var s=getNodeById(e.from),t=getNodeById(e.to);if(!s||!t)return;
    var sx=s.x+80,sy=s.y+68,tx=t.x+80,ty=t.y;
    var mid=(sy+ty)/2;
    var path=document.createElementNS(ns,'path');
    path.setAttribute('d','M '+sx+' '+sy+' C '+sx+' '+mid+', '+tx+' '+mid+', '+tx+' '+ty);
    path.setAttribute('fill','none');path.setAttribute('stroke','#5eac2c');
    path.setAttribute('stroke-width','2');path.setAttribute('marker-end','url(#b-arrow)');
    path.setAttribute('opacity','0.85');
    svgEl.appendChild(path);
  });

  // Draw nodes
  builderNodes.forEach(function(n){
    var el=document.createElement('div');
    var isSelected=selNode===n.id;
    var isWarn=n.name==='Retest Requested'||n.name==='Approval Pending';
    el.className='builder-node'+(isSelected?' selected':'')+(isWarn?' bottleneck-node':'');
    el.style.left=n.x+'px';el.style.top=n.y+'px';
    el.setAttribute('data-nid',n.id);

    var roleCol=n.role==='QA Manager'?'#fff5e8':n.role==='Lab Tech'?'#eff3ff':'#f0f9f4';
    var roleTC=n.role==='QA Manager'?'#b7770d':n.role==='Lab Tech'?'#3b50b5':'#004e2b';
    el.innerHTML=
      '<span class="node-del" data-nid="'+n.id+'">x</span>'+
      '<div class="node-title">'+n.name+'</div>'+
      '<div class="node-meta">'+n.dur+'m . '+n.role+'</div>'+
      '<div class="node-port out" data-nid="'+n.id+'" title="Drag to connect"></div>';

    // Delete
    el.querySelector('.node-del').addEventListener('click',function(ev){
      ev.stopPropagation();deleteNode(n.id);
    });

    // Port mousedown - draw temp line and connect on release
    el.querySelector('.node-port').addEventListener('mousedown',function(ev){
      ev.stopPropagation();ev.preventDefault();
      var canvas=document.getElementById('builder-canvas');
      svgEl.style.pointerEvents='none'; // keep SVG transparent to hit-test
      // Temp line
      var tl=document.createElementNS('http://www.w3.org/2000/svg','line');
      tl.setAttribute('stroke','#5eac2c');tl.setAttribute('stroke-width','2');
      tl.setAttribute('stroke-dasharray','6,3');tl.setAttribute('opacity','0.8');
      tl.setAttribute('pointer-events','none');
      var cr=canvas.getBoundingClientRect();
      var ox=n.x+80,oy=n.y+68;
      tl.setAttribute('x1',ox);tl.setAttribute('y1',oy);
      tl.setAttribute('x2',ox);tl.setAttribute('y2',oy);
      svgEl.appendChild(tl);
      function onMove(me){
        tl.setAttribute('x2',me.clientX-cr.left);
        tl.setAttribute('y2',me.clientY-cr.top);
      }
      function onUp(me){
        document.removeEventListener('mousemove',onMove);
        document.removeEventListener('mouseup',onUp);
        if(tl.parentNode){tl.parentNode.removeChild(tl);}
        // Hit-test by bounding box - avoids SVG overlay blocking elementsFromPoint
        var toId=null;
        var allNodeEls=document.querySelectorAll('#builder-nodes .builder-node');
        for(var i=0;i<allNodeEls.length;i++){
          var el2=allNodeEls[i];
          if(el2.dataset.nid===n.id)continue;
          var r=el2.getBoundingClientRect();
          if(me.clientX>=r.left&&me.clientX<=r.right&&me.clientY>=r.top&&me.clientY<=r.bottom){
            toId=el2.dataset.nid;
            break;
          }
        }
        if(toId){
          var exists=builderEdges.some(function(e){return e.from===n.id&&e.to===toId;});
          if(!exists){
            pushUndo();
            builderEdges.push({from:n.id,to:toId});
            var tNode=getNodeById(toId);
            document.getElementById('builder-status').textContent='Connected: '+n.name+' -> '+(tNode?tNode.name:toId);
          }
        } else {
          document.getElementById('builder-status').textContent='Drop onto another node to connect';
        }
        renderBuilder();
      }
      document.addEventListener('mousemove',onMove);
      document.addEventListener('mouseup',onUp);
    });

    // Node drag - update position live, only re-render edges (fast)
    el.addEventListener('mousedown',function(ev){
      if(ev.target.classList.contains('node-port')||ev.target.classList.contains('node-del'))return;
      ev.preventDefault();
      selectBuilderNode(n.id);
      var sx2=ev.clientX-n.x,sy2=ev.clientY-n.y;
      var moved=false;
      function onMove(me){
        moved=true;
        n.x=me.clientX-sx2;
        n.y=me.clientY-sy2;
        // Clamp to canvas
        n.x=Math.max(0,Math.min(n.x,880));
        n.y=Math.max(0,Math.min(n.y,440));
        el.style.left=n.x+'px';
        el.style.top=n.y+'px';
        // Fast edge-only redraw
        var paths=svgEl.querySelectorAll('path:not(defs path),line');
        paths.forEach(function(p){if(p.parentNode===svgEl)p.parentNode.removeChild(p);});
        builderEdges.forEach(function(e){
          var s2=getNodeById(e.from),t2=getNodeById(e.to);if(!s2||!t2)return;
          var px=s2.x+80,py=s2.y+68,qx=t2.x+80,qy=t2.y;
          var pm=(py+qy)/2;
          var p2=document.createElementNS('http://www.w3.org/2000/svg','path');
          p2.setAttribute('d','M '+px+' '+py+' C '+px+' '+pm+', '+qx+' '+pm+', '+qx+' '+qy);
          p2.setAttribute('fill','none');p2.setAttribute('stroke','#5eac2c');
          p2.setAttribute('stroke-width','2');p2.setAttribute('marker-end','url(#b-arrow)');
          p2.setAttribute('opacity','0.85');
          svgEl.appendChild(p2);
        });
      }
      function onUp(){
        document.removeEventListener('mousemove',onMove);
        document.removeEventListener('mouseup',onUp);
        if(moved)renderBuilder();
      }
      document.addEventListener('mousemove',onMove);
      document.addEventListener('mouseup',onUp);
    });

    container.appendChild(el);
  });
  updateBuilderStats();
}

