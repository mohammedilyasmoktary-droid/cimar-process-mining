function showDeptLogin(deptId) {
  var dept = DEPT_REGISTRY.filter(function(d){ return d.id === deptId; })[0];
  if (!dept) return;
  window._loginDept = dept;

  // Populate login panel with dept info
  var nameEl   = document.getElementById('login-dept-name');
  var descEl   = document.getElementById('login-dept-desc');
  var titleEl  = document.getElementById('login-form-title');
  if (nameEl)  nameEl.textContent  = dept.name;
  if (descEl)  descEl.textContent  = dept.desc;
  if (titleEl) titleEl.textContent = 'Sign in to ' + dept.name;

  // Clear any previous form state
  var emailEl = document.getElementById('login-email');
  var passEl  = document.getElementById('login-password');
  var errEl   = document.getElementById('login-error');
  if (emailEl) emailEl.value = '';
  if (passEl)  passEl.value  = '';
  if (errEl)   errEl.classList.remove('visible');
  if (emailEl) emailEl.classList.remove('error');
  if (passEl)  passEl.classList.remove('error');

  // Hide selection + dept views, show login view
  var selView   = document.getElementById('entry-select-view');
  var deptView  = document.getElementById('entry-dept-view');
  var loginView = document.getElementById('entry-login-view');
  if (selView)  selView.style.display  = 'none';
  if (deptView) deptView.classList.remove('visible');
  if (loginView) loginView.classList.add('visible');

  // Focus email field
  setTimeout(function(){ if (emailEl) emailEl.focus(); }, 120);
}

// Called when user submits the login form
function handleDeptLogin() {
  var dept = window._loginDept;
  if (!dept) return;

  var emailEl = document.getElementById('login-email');
  var passEl  = document.getElementById('login-password');
  var errEl   = document.getElementById('login-error');
  var btnEl   = document.getElementById('login-btn');

  var email = emailEl ? emailEl.value.trim() : '';
  var pass  = passEl  ? passEl.value         : '';

  // Basic validation
  var hasError = false;
  if (!email || email.indexOf('@') < 0) {
    if (emailEl) emailEl.classList.add('error');
    hasError = true;
  } else {
    if (emailEl) emailEl.classList.remove('error');
  }
  if (!pass || pass.length < 3) {
    if (passEl) passEl.classList.add('error');
    hasError = true;
  } else {
    if (passEl) passEl.classList.remove('error');
  }

  if (hasError) {
    if (errEl) errEl.classList.add('visible');
    return;
  }

  // Success: loading state on button
  if (btnEl) {
    btnEl.textContent = 'Signing in...';
    btnEl.disabled = true;
  }

  // Mock auth delay then enter department
  setTimeout(function() {
    if (btnEl) { btnEl.textContent = 'Sign in to department'; btnEl.disabled = false; }
    // Hide entry screen, load platform
    var loginView = document.getElementById('entry-login-view');
    if (loginView) loginView.classList.remove('visible');
    enterDepartment(dept.id);
  }, 900);
}

// Allow Enter key to submit login form
document.addEventListener('keydown', function(e) {
  if (e.key === 'Enter') {
    var lv = document.getElementById('entry-login-view');
    if (lv && lv.classList.contains('visible')) {
      handleDeptLogin();
    }
  }
});

