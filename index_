              +'<span style="font-size:12px;color:'+(i===0?'#c0392b':'var(--text)')+'">'+a.a+'</span>'
              +'<div class="mbar-wrap" style="height:8px"><div class="mbar-fill" style="width:'+Math.min(100,a.avg/D.bns[0].avg*100)+'%;background:'+bc+';height:100%"></div></div>'
