          if(phEl)phEl.textContent='Ciments du Maroc . '+plants.length+' plants . '+fmtD(minD)+' -> '+fmtD(maxD)+' . '+cases.length+' cases';

          // Re-render dashboard wait bars + plant table
          var mx=actStats.length?actStats[0].avg:1;
          var wbHtml='';
          actStats.filter(function(a){return a.avg>0;}).slice(0,8).forEach(function(a){
            wbHtml+='<div style="margin-bottom:11px"><div style="display:flex;justify-content:space-between;margin-bottom:4px">'
              +'<span style="font-size:11px;color:'+(a.avg>90?'#c0392b':'var(--textm)')+'">'+a.a+'</span>'
              +'<span style="font-size:11px;color:'+(a.avg>90?'#c0392b':a.avg>30?'#b7770d':'#4a6b4e')+';font-family:DM Mono,monospace">'+a.avg.toFixed(0)+'m . p90 '+a.p90.toFixed(0)+'m</span></div>'
              +'<div class="mbar-wrap" style="height:8px"><div class="mbar-fill" style="width:'+Math.min(100,a.avg/mx*100)+'%;background:'+a.col+';height:100%"></div></div></div>';
          });
          var wbEl=document.getElementById('wait-bars');if(wbEl)wbEl.innerHTML=wbHtml;

          // Update bold plant status rows
          var plantMaxHrs=Math.max.apply(null,D.plants.map(function(p){return p.hrs;}));
          var prHtml2='';
          D.plants.slice().sort(function(a,b){return a.hrs-b.hrs;}).forEach(function(p){
