    var diff=a!==null&&b!==null?b-a:null;
    var diffStr=diff!==null?(diff>0?'+':'')+Math.round(diff)+'m':'--';
    var diffCol=diff===null?'var(--textd)':diff>10?'#c0392b':diff<-10?'#22883f':'var(--textm)';
    var maxV=Math.max(a||0,b||0);
    var barA=maxV>0&&a!==null?'<div style="height:4px;background:#22883f;border-radius:2px;width:'+Math.round(a/maxV*100)+'%"></div>':'';
    var barB=maxV>0&&b!==null?'<div style="height:4px;background:#b7770d;border-radius:2px;width:'+Math.round(b/maxV*100)+'%;margin-top:2px"></div>':'';
    actHtml+='<tr><td style="padding:8px;border-bottom:1px solid var(--border)">'+act+'</td>'
      +'<td style="text-align:right;padding:8px;border-bottom:1px solid var(--border);font-family:DM Mono,monospace;color:#22883f">'+aStr+'</td>'
      +'<td style="text-align:right;padding:8px;border-bottom:1px solid var(--border);font-family:DM Mono,monospace;color:#b7770d">'+bStr+'</td>'
      +'<td style="text-align:right;padding:8px;border-bottom:1px solid var(--border);font-family:DM Mono,monospace;color:'+diffCol+'">'+diffStr+'</td>'
      +'<td style="padding:8px;border-bottom:1px solid var(--border);min-width:80px">'+barA+barB+'</td></tr>';
  });
  actHtml+='</tbody></table>';
  document.getElementById('cmp-act-table').innerHTML=actHtml;

  // Deviations
  var aSet={};A.acts.forEach(function(a){aSet[a]=true;});
  var bSet={};B.acts.forEach(function(b){bSet[b]=true;});
