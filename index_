function renderDFG(){
  // Always use dfg-wrap as the canonical container
  var container=document.getElementById('dfg-wrap');
  if(!container){container=document.getElementById('dfg-container');}
  if(!container){console.warn('DFG container not found');return;}
  // Remove any existing SVG inside container
  var oldSvg=container.querySelector('svg');
  if(oldSvg&&oldSvg.parentNode===container){container.removeChild(oldSvg);}
  var W=container.offsetWidth||800,H=container.offsetHeight||560;
  var svgEl=document.createElementNS('http://www.w3.org/2000/svg','svg');
  svgEl.setAttribute('width',W);svgEl.setAttribute('height',H);
  svgEl.style.width='100%';svgEl.style.height='100%';
  container.insertBefore(svgEl,container.firstChild);
  var svg=d3.select(svgEl);
  dfgSvg=svg;
  var defs=svg.append('defs');
  defs.append('marker').attr('id','dfg-arrow').attr('viewBox','0 0 10 10').attr('refX',8).attr('refY',5).attr('markerWidth',6).attr('markerHeight',6).attr('orient','auto-start-reverse').append('path').attr('d','M2 2L8 5L2 8').attr('fill','none').attr('stroke','#b8ccba').attr('stroke-width',1.5);
  defs.append('marker').attr('id','dfg-arrow-red').attr('viewBox','0 0 10 10').attr('refX',8).attr('refY',5).attr('markerWidth',6).attr('markerHeight',6).attr('orient','auto-start-reverse').append('path').attr('d','M2 2L8 5L2 8').attr('fill','none').attr('stroke','#e8a89e').attr('stroke-width',1.5);
  defs.append('marker').attr('id','dfg-arrow-amber').attr('viewBox','0 0 10 10').attr('refX',8).attr('refY',5).attr('markerWidth',6).attr('markerHeight',6).attr('orient','auto-start-reverse').append('path').attr('d','M2 2L8 5L2 8').attr('fill','none').attr('stroke','#f5c542').attr('stroke-width',1.5);

  var zoom=d3.zoom().scaleExtent([0.25,3]).on('zoom',function(event){g.attr('transform',event.transform);});
  dfgZoom=zoom; svg.call(zoom);
  var g=svg.append('g'); dfgG=g;

  var NW=170,NH=52;

  // Build nodes dynamically from D.acts and D.edges
  // Determine node order using topological sort on edges
  var edgeMap={};
  var inDegree={};
  D.acts.forEach(function(a){inDegree[a.a]=0;});
  D.edges.forEach(function(e){
    if(!edgeMap[e.f])edgeMap[e.f]=[];
    edgeMap[e.f].push(e.t);
    if(inDegree[e.t]===undefined)inDegree[e.t]=0;
    inDegree[e.t]=(inDegree[e.t]||0)+1;
  });

  // Topological sort (Kahns algorithm) to get main flow order
  var queue=D.acts.filter(function(a){return !inDegree[a.a];}).map(function(a){return a.a;});
  if(!queue.length){
    // fallback: start with highest count node
    var sorted=D.acts.slice().sort(function(a,b){return b.cnt-a.cnt;});
    queue=[sorted[0].a];
  }
  var ordered=[];var visited={};
  while(queue.length){
    var cur=queue.shift();
    if(visited[cur])continue;
    visited[cur]=true;
    ordered.push(cur);
    (edgeMap[cur]||[]).forEach(function(next){
      if(!visited[next])queue.push(next);
    });
  }
  // Add any remaining acts not reachable
  D.acts.forEach(function(a){if(!visited[a.a])ordered.push(a.a);});

  // Detect loops/rework nodes (nodes with back-edges to earlier nodes)
  var orderedIdx={};
  ordered.forEach(function(id,i){orderedIdx[id]=i;});
  var reworkNodes={};
  D.edges.forEach(function(e){
    if(orderedIdx[e.f]!==undefined&&orderedIdx[e.t]!==undefined&&orderedIdx[e.t]<orderedIdx[e.f]){
      reworkNodes[e.f]=true;reworkNodes[e.t]=true;
    }
  });

  // Assign positions: main flow goes LEFT-TO-RIGHT in a center row
  // Rework/loop nodes go to a row BELOW the main flow
  var mainFlow=ordered.filter(function(id){return !reworkNodes[id]||D.acts.some(function(a){return a.a===id&&a.cnt>(D.acts[0].cnt*0.5);});});
  var sideFlow=ordered.filter(function(id){return reworkNodes[id]&&mainFlow.indexOf(id)<0;});

  // Horizontal layout parameters
  var stepX=NW+80;                              // space between node centres horizontally
  var totalW=mainFlow.length*stepX-80;
  var startX=Math.max(20,(W-totalW)/2);         // centre the row in the viewport
  var mainY=Math.max(20,(H-NH)/2-60);           // main row vertical centre (upper half)
  var sideY=mainY+NH+110;                        // rework row below main row

  var nodes=[];
  mainFlow.forEach(function(id,i){
    var act=D.acts.find(function(a){return a.a===id;})||{cnt:0,avg:0,p90:0};
    var col=act.avg>90?'#fff5f0':act.avg>30?'#fffbeb':'#f0f9f4';
    var sc=act.avg>90?'#c0392b':act.avg>30?'#b7770d':'#5eac2c';
    nodes.push({id:id,x:startX+i*stepX,y:mainY,avg:act.avg||0,p90:act.p90||0,cnt:act.cnt||0,max:act.max||0,col:col,sc:sc});
  });
  sideFlow.forEach(function(id,i){
    var act=D.acts.find(function(a){return a.a===id;})||{cnt:0,avg:0,p90:0};
    var col='#fff5f5';var sc='#c0392b';
    // Place rework nodes below, horizontally near the middle of the main flow
    var midX=startX+(mainFlow.length/2)*stepX-NW/2-stepX/2+i*stepX;
    nodes.push({id:id,x:midX,y:sideY,avg:act.avg||0,p90:act.p90||0,cnt:act.cnt||0,max:act.max||0,col:col,sc:sc});
  });
  var maxCnt=Math.max.apply(null,nodes.map(function(n){return n.cnt;}));
  var maxEdge=Math.max.apply(null,D.edges.map(function(e){return e.c;}));
  var activeFilter=null;

  // EDGE LINES (drawn first, behind nodes)
  var edgePaths={};
  D.edges.forEach(function(e,ei){
    var s=nodes.find(function(n){return n.id===e.f;}),t=nodes.find(function(n){return n.id===e.t;});
    if(!s||!t)return;
    var sw=Math.max(1.5,(e.c/maxEdge)*7);
    var isRework=reworkNodes[e.f]||reworkNodes[e.t];
    var isSlow=e.avg>90;
    var col=isRework?'#e8a89e':isSlow?'#f5c542':'#a8d5b5';
    var markerId=isRework?'url(#dfg-arrow-red)':isSlow?'url(#dfg-arrow-amber)':'url(#dfg-arrow)';
    var path;
    if(isRework){
      if(e.t==='Retest Requested'){
        path=g.append('path').attr('fill','none').attr('stroke',col).attr('stroke-width',sw).attr('stroke-dasharray','7,3').attr('marker-end',markerId).attr('opacity',0.85).attr('class','flow-animated');
      } else {
        path=g.append('path').attr('fill','none').attr('stroke',col).attr('stroke-width',sw).attr('stroke-dasharray','7,3').attr('marker-end',markerId).attr('opacity',0.85).attr('class','flow-animated');
      }
    } else {
      path=g.append('path').attr('fill','none').attr('stroke',col).attr('stroke-width',sw).attr('marker-end',markerId).attr('opacity',0.9);
      if(isSlow)path.attr('class','flow-animated').attr('stroke-dasharray','8,3');
    }
    edgePaths[ei]={path:path,s:s,t:t,e:e,isRework:isRework};
    // edge time label
    var labelG=g.append('g').attr('class','edge-label');
    labelG.append('rect').attr('rx',3).attr('fill','#fff').attr('opacity',0.85).attr('stroke',col).attr('stroke-width',0.5);
    labelG.append('text').attr('text-anchor','middle').attr('dominant-baseline','central').attr('fill',isSlow?'#b7770d':isRework?'#c0392b':'#8aaa8e').attr('font-size',9).attr('font-family','DM Mono,monospace').text(Math.round(e.avg)+'m');
    edgePaths[ei].label=labelG;
  });

  function updateEdgePositions(){
    Object.keys(edgePaths).forEach(function(ei){
      var ep=edgePaths[ei];
      var s=ep.s,t=ep.t,e=ep.e;
      // Horizontal layout: edges exit RIGHT side of source, enter LEFT side of target
      var x1=s.x+NW, y1=s.y+NH/2;   // right-centre of source
      var x2=t.x,    y2=t.y+NH/2;   // left-centre of target
      var d;
      if(ep.isRework){
        // Rework nodes are BELOW main row   curve down then across then back up
        var cx=(x1+x2)/2;
        var dropY=Math.max(s.y,t.y)+NH+55; // below both nodes
        d='M '+x1+' '+y1
          +' C '+x1+' '+dropY+', '+x2+' '+dropY+', '+x2+' '+y2;
      } else if(s.y!==t.y){
        // Cross-row edge (main   side or side   main): curve smoothly
        var cx=(x1+x2)/2;
        d='M '+x1+' '+y1+' C '+cx+' '+y1+', '+cx+' '+y2+', '+x2+' '+y2;
      } else {
        // Same row: horizontal cubic bezier
        var mid=(x1+x2)/2;
        d='M '+x1+' '+y1+' C '+mid+' '+y1+', '+mid+' '+y2+', '+x2+' '+y2;
      }
      ep.path.attr('d',d);
      // Label at midpoint of path
      var mx=(x1+x2)/2, my=(y1+y2)/2;
      if(ep.isRework){ my=Math.max(s.y,t.y)+NH+55; }
      var txt=ep.label.select('text');
      var tw=Math.round(e.avg).toString().length*6+12;
      ep.label.select('rect').attr('x',mx-tw/2).attr('y',my-8).attr('width',tw).attr('height',16);
      txt.attr('x',mx).attr('y',my);
    });
  }

  // NODES (draggable)
  nodes.forEach(function(n){
    var isBottle=n.id==='Approval Pending';
    var isRework=n.id==='Retest Requested';
    var nodeG=g.append('g').attr('class','dfg-node').attr('cursor','grab');

    nodeG.append('rect').attr('x',n.x).attr('y',n.y).attr('width',NW).attr('height',NH)
      .attr('rx',8).attr('fill',n.col).attr('stroke',n.sc).attr('stroke-width',isBottle||isRework?2:1.5)
      .attr('filter',isBottle?'drop-shadow(0 2px 8px rgba(192,57,43,.2))':isRework?'drop-shadow(0 2px 6px rgba(192,57,43,.12))':'drop-shadow(0 1px 4px rgba(0,0,0,.06))');

    if(isBottle){
      nodeG.append('rect').attr('x',n.x+4).attr('y',n.y+4).attr('width',NW-8).attr('height',NH-8).attr('rx',5).attr('fill','none').attr('stroke','#c0392b').attr('stroke-width',0.5).attr('stroke-dasharray','4,3').attr('opacity',0.5);
    }

    nodeG.append('text').attr('x',n.x+NW/2).attr('y',n.y+19).attr('text-anchor','middle').attr('dominant-baseline','central').attr('fill','#1a2e1c').attr('font-size',12).attr('font-weight',600).attr('font-family','Inter,sans-serif').text(n.id);

    var cntLabel=nodeG.append('text').attr('x',n.x+NW/2).attr('y',n.y+36).attr('text-anchor','middle').attr('dominant-baseline','central').attr('fill',n.avg>90?'#c0392b':n.avg>30?'#b7770d':'#4a6b4e').attr('font-size',9).attr('font-family','DM Mono,monospace')
      .text(n.cnt.toLocaleString()+' events'+(n.avg>0?' . '+n.avg.toFixed(0)+'m':''));

    // Status dot
    nodeG.append('circle').attr('cx',n.x+NW-10).attr('cy',n.y+10).attr('r',4)
      .attr('fill',n.avg>90?'#c0392b':n.avg>30?'#b7770d':'#22883f');

    // DRAG behaviour
    var drag=d3.drag()
      .on('start',function(){d3.select(this).attr('cursor','grabbing');})
      .on('drag',function(event){
        n.x+=event.dx; n.y+=event.dy;
        d3.select(this).select('rect').attr('x',n.x).attr('y',n.y);
        d3.select(this).selectAll('text').each(function(){
          var t=d3.select(this);
          if(t.attr('text-anchor')==='middle'){t.attr('x',n.x+NW/2);}
          t.attr('y',parseFloat(t.attr('y'))+event.dy);
        });
        d3.select(this).selectAll('circle').attr('cx',n.x+NW-10).attr('cy',n.y+10);
        d3.select(this).selectAll('rect').filter(function(d,i){return i>0;}).attr('x',n.x+4).attr('y',n.y+4);
        updateEdgePositions();
      })
      .on('end',function(){d3.select(this).attr('cursor','grab');});

    nodeG.call(drag);

    // CLICK to filter
    nodeG.on('click',function(event){
      event.stopPropagation();
      if(activeFilter===n.id){
        activeFilter=null;
        g.selectAll('.dfg-node').attr('opacity',1);
        g.selectAll('path,line').attr('opacity',function(){return this.parentNode===g.node()?0.9:1;});
        showNodeDetail(n);
      } else {
        activeFilter=n.id;
        filterDashboardByNode(n);
        g.selectAll('.dfg-node').attr('opacity',0.25);
        d3.select(this).attr('opacity',1);
        // Highlight connected edges
        var connectedNodes={};connectedNodes[n.id]=true;
        activeEdges.forEach(function(e){if(e.f===n.id)connectedNodes[e.t]=true;if(e.t===n.id)connectedNodes[e.f]=true;});
        g.selectAll('.dfg-node').each(function(d,i){
          var nm=d3.select(this).select('text').text();
          nodes.forEach(function(nd){if(nd.id in connectedNodes)d3.selectAll('.dfg-node').filter(function(){return d3.select(this).select('text').text()===nd.id;}).attr('opacity',0.8);});
        });
        showNodeDetail(n);
      }
    })
    .on('mouseover',function(event){if(!event.buttons)showDFGTooltip(event,n,PLANT_FACTOR[currentPlant]||1);})
    .on('mouseout',function(){var t=document.getElementById('dfg-tip');if(t)t.classList.remove('show');});
  });

  // Click background to clear filter
  svg.on('click',function(){
    activeFilter=null;
    g.selectAll('.dfg-node').attr('opacity',1);
    document.getElementById('node-detail').innerHTML='<div style="font-size:12px;color:var(--textm);padding:20px 0;text-align:center">Click any node in the process map above</div>';
  });

  updateEdgePositions();
  svg.call(zoom.transform,d3.zoomIdentity.translate(20,H*0.18).scale(0.82));

  // Edge table
  var et='';
  D.edges.slice().sort(function(a,b){return b.avg-a.avg;}).forEach(function(e){
    var slow=e.avg>90,isRew=e.f==='Retest Requested'||e.t==='Retest Requested';
    et+='<tr><td style="font-size:11px;color:'+(slow||isRew?'#b7770d':'var(--text)')+'">'+e.f.split(' ')[0]+'</td>'
      +'<td style="font-size:11px;color:'+(slow||isRew?'#b7770d':'var(--text)')+'">'+e.t.split(' ')[0]+'</td>'
      +'<td style="text-align:right;color:var(--textm);font-family:DM Mono,monospace">'+e.c+'</td>'
      +'<td style="text-align:right;color:'+(slow?'#c0392b':isRew?'#b7770d':'var(--text)')+';font-family:DM Mono,monospace;font-weight:'+(slow?600:400)+'">'+e.avg.toFixed(0)+'m</td></tr>';
  });
  document.getElementById('edge-tbl').innerHTML=et;
}

