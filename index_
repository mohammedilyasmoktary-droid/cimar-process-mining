              +'</div>';
          });
          var arEl2=document.getElementById('activity-status-rows');if(arEl2)arEl2.innerHTML=arHtml2;

          var mxSpd=plantStats.length?1/Math.min.apply(null,plantStats.map(function(p){return p.hrs;})):1;
