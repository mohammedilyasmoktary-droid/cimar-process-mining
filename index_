  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 18px;
  margin-top: 2px;
}
.pf-stage-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2px solid currentColor;
  background: #fff;
  box-shadow: 0 0 0 2px rgba(255,255,255,.5);
  z-index: 1;
}
