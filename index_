}


function renderDFGEdgesOnly(){
  // Redraw edges during drag without full re-render
  dfgG.selectAll('line,path').remove();
  dfgG.selectAll('text.edge-label').remove();
  // Simple redraw
  var fac=PLANT_FACTOR[currentPlant]||1;
  var maxE=Math.max.apply(null,activeEdges.map(function(e){return e.c;}))||1;
  D.edges.forEach(function(e){
    var s=dfgNodes.find(function(n){return n.id===e.f;});
    var t=dfgNodes.find(function(n){return n.id===e.t;});
    if(!s||!t)return;
    var sw=Math.max(1.5,(e.c/maxE)*7);
    var isRew=e.f==='Retest Requested'||e.t==='Retest Requested';
    var col=isRew?'#e8a89e':e.avg>90?'#f5c87e':'#a8d5b5';
    var mtype=isRew?'rework':e.avg>90?'slow':'normal';
    var NW=168,NH=52;
    var x1=s.x+NW/2,y1=s.y+NH,x2=t.x+NW/2,y2=t.y;
    if(e.t==='Retest Requested'){
      dfgG.insert('path','.dfg-node-g').attr('d','M '+x1+' '+(s.y+NH/2)+' C '+(x1+50)+' '+y1+', '+(t.x+NW+50)+' '+t.y+', '+(t.x+NW)+' '+(t.y+NH/2)).attr('fill','none').attr('stroke',col).attr('stroke-width',sw).attr('stroke-dasharray','6,3').attr('marker-end','url(#arr-'+mtype+')');
    } else if(e.f==='Retest Requested'){
      dfgG.insert('path','.dfg-node-g').attr('d','M '+(t.x+NW)+' '+(s.y+NH/2)+' C '+(t.x+NW+80)+' '+s.y+', '+(x2+80)+' '+(y2+NH)+', '+(x2+4)+' '+(y2+NH/2)).attr('fill','none').attr('stroke',col).attr('stroke-width',sw).attr('stroke-dasharray','6,3').attr('marker-end','url(#arr-'+mtype+')');
    } else {
      dfgG.insert('line','.dfg-node-g').attr('x1',x1).attr('y1',y1).attr('x2',x2).attr('y2',y2).attr('stroke',col).attr('stroke-width',sw).attr('marker-end','url(#arr-'+mtype+')');
    }
  });
}

function startParticles(fac){
  if(particleTimer)clearInterval(particleTimer);
  var mainEdges=D.edges.filter(function(e){return e.f!=='Retest Requested'&&e.t!=='Retest Requested'&&e.c>100;});
  particleTimer=setInterval(function(){
    if(!dfgG)return;
    var e=mainEdges[Math.floor(Math.random()*mainEdges.length)];
    if(!e)return;
    var s=dfgNodes.find(function(n){return n.id===e.f;});
    var t=dfgNodes.find(function(n){return n.id===e.t;});
    if(!s||!t)return;
    var NW=168,NH=52;
    var x1=s.x+NW/2,y1=s.y+NH,x2=t.x+NW/2,y2=t.y;
    var col=e.avg*fac>90?'#c0392b':e.avg*fac>30?'#b7770d':'#22883f';
    var p=dfgG.append('circle').attr('r',4).attr('cx',x1).attr('cy',y1).attr('fill',col).attr('opacity',0.8);
    p.transition().duration(1200).ease(d3.easeLinear)
      .attr('cx',x2).attr('cy',y2).attr('opacity',0)
      .on('end',function(){d3.select(this).remove();});
  },300);
}

