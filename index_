  var email = eEl ? eEl.value.trim() : '';
  var pass  = pEl ? pEl.value : '';
  var ok    = email.indexOf('@') > 0 && pass.length >= 3;
  if(!ok){
    if(errEl) errEl.classList.add('show');
    if(eEl && email.indexOf('@') < 0) eEl.classList.add('err');
    if(pEl && pass.length < 3) pEl.classList.add('err');
    return;
  }
  if(errEl) errEl.classList.remove('show');
  if(eEl)  eEl.classList.remove('err');
  if(pEl)  pEl.classList.remove('err');
  if(btnEl){ btnEl.textContent = 'Signing in...'; btnEl.disabled = true; }
  setTimeout(function(){
    if(btnEl){ btnEl.textContent = 'Sign in to platform'; btnEl.disabled = false; }
    var access = resolveAccess(email);
    APP_STATE.user       = access;
    APP_STATE.accessDepts = access.access;
    var h = new Date().getHours();
    var salut = h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening';
    var greet = document.getElementById('acc-greeting');
    var sub   = document.getElementById('acc-sub');
    var chip  = document.getElementById('acc-email-chip');
    if(greet) greet.textContent = salut + ', ' + access.role;
    if(sub)   sub.textContent   = access.access.length + ' department' + (access.access.length !== 1 ? 's' : '') + ' accessible';
    if(chip)  chip.textContent  = email;
    renderAccessView();
    goToStep(2);
  }, 700);
}

