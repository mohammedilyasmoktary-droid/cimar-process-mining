function drawChart(id,labels,values,colors,height){
  var cv=document.getElementById(id);if(!cv)return;
  var dpr=window.devicePixelRatio||1;
  var w=cv.offsetWidth||cv.parentElement.offsetWidth||400;
  cv.width=w*dpr;cv.height=height*dpr;cv.style.height=height+'px';
  var ctx=cv.getContext('2d');ctx.scale(dpr,dpr);
  ctx.clearRect(0,0,w,height);
  var pad={t:8,r:8,b:36,l:48};
  var cw=w-pad.l-pad.r,ch=height-pad.t-pad.b;
  var mx=Math.max.apply(null,values)*1.12;
  var bw=(cw/values.length)*0.58,bg=(cw/values.length)*0.42;
  [0.25,0.5,0.75,1].forEach(function(f){
    var y=pad.t+ch-ch*f;
    ctx.strokeStyle='#e8ede8';ctx.lineWidth=0.5;
    ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(pad.l+cw,y);ctx.stroke();
    ctx.fillStyle='#93b09a';ctx.font='10px monospace';ctx.textAlign='right';
    var v=mx*f;ctx.fillText(v>=100?Math.round(v):v.toFixed(1),pad.l-4,y+4);
  });
  values.forEach(function(v,i){
    var x=pad.l+i*(bw+bg)+bg/2,bh=(v/mx)*ch,y=pad.t+ch-bh;
    ctx.fillStyle=Array.isArray(colors)?colors[i]:colors;
    ctx.beginPath();if(ctx.roundRect){ctx.roundRect(x,y,bw,bh,3);}else{ctx.rect(x,y,bw,bh);}ctx.fill();
    ctx.fillStyle='#93b09a';ctx.font='10px monospace';ctx.textAlign='center';
    var lbl=labels[i],ml=Math.max(4,Math.floor(bw/6));
    ctx.fillText(lbl.length>ml?lbl.slice(0,ml-1)+'...':lbl,x+bw/2,pad.t+ch+16);
  });
}

// -- SPARKLINES ----------------------------------------------------------------
function drawSpark(containerId,data,upIsGood){
  var wrap=document.getElementById(containerId);
  if(!wrap||!wrap.offsetParent)return;
  var el=document.getElementById(containerId);if(!el)return;
  var max=Math.max.apply(null,data),min=Math.min.apply(null,data);
  var range=max-min||1;
  var h='';
  data.forEach(function(v,i){
    var pct=Math.round(((v-min)/range)*100);
    var isLast=i===data.length-1;
    var trend=data[data.length-1]>data[0];
    var col=isLast?(upIsGood?(trend?'#22883f':'#c0392b'):(trend?'#c0392b':'#22883f')):'#b8ccba';
    h+='<div class="spark-bar" style="height:'+(4+pct/100*14)+'px;background:'+col+';flex:1;border-radius:1px"></div>';
  });
  el.innerHTML=h;
}

