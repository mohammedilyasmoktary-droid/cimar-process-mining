function generateBuilderRecs(){
  if(!builderNodes.length){document.getElementById('builder-status').textContent='Build a process first';return;}
  // Analyse the designed process and generate recommendations
  var recs=[];
  var totalDur=builderNodes.reduce(function(s,n){return s+(+n.dur||0);},0);
  var avgDur=totalDur/builderNodes.length;
  // Find slowest steps
  var sorted=builderNodes.slice().sort(function(a,b){return b.dur-a.dur;});
  var slowest=sorted[0];
  var bottlenecks=builderNodes.filter(function(n){return n.dur>avgDur*1.5;});
  // Check for missing steps
  var names=builderNodes.map(function(n){return n.name.toLowerCase();});
  var hasApproval=names.some(function(n){return n.indexOf('approv')>=0;});
  var hasQC=names.some(function(n){return n.indexOf('quality')>=0||n.indexOf('check')>=0||n.indexOf('inspect')>=0;});
  var hasReport=names.some(function(n){return n.indexOf('report')>=0||n.indexOf('document')>=0;});
  // Check for disconnected nodes
  var connected={};
  builderEdges.forEach(function(e){connected[e.from]=true;connected[e.to]=true;});
  var isolated=builderNodes.filter(function(n){return !connected[n.id];});

  if(bottlenecks.length>0){
    bottlenecks.forEach(function(b){
      recs.push({id:'BR-'+recs.length,s:'critical',cat:'Design Bottleneck',
        title:'Long Step: '+b.name,
        issue:b.name+' is designed at '+b.dur+'m - '+(b.dur/avgDur).toFixed(1)+'x the process average of '+Math.round(avgDur)+'m.',
        cause:'This step may create a queue. Consider splitting it or assigning more resources.',
        action:'1. Split into sub-steps. 2. Assign dedicated resource. 3. Set max duration target.',
        impact:'Reducing by 30% saves ~'+Math.round(b.dur*0.3)+'m per case.'});
    });
  }
  if(isolated.length>0){
    recs.push({id:'BR-'+recs.length,s:'critical',cat:'Design Gap',
      title:'Disconnected Steps Found',
      issue:isolated.map(function(n){return n.name;}).join(', ')+' have no connections.',
      cause:'Isolated steps are never reached in the process flow.',
      action:'1. Connect all steps. 2. Remove unused steps. 3. Use Auto Layout to review flow.',
      impact:'Ensures process completeness and accurate timing estimates.'});
  }
  if(!hasApproval){
    recs.push({id:'BR-'+recs.length,s:'warning',cat:'Missing Step',
      title:'No Approval Step Defined',
      issue:'Your designed process has no approval or sign-off step.',
      cause:'Approval steps are required for quality certification in cement production.',
      action:'Add an Approval Pending step before the final output.',
      impact:'Prevents non-conforming samples from reaching the report stage.'});
  }
  if(!hasReport){
    recs.push({id:'BR-'+recs.length,s:'warning',cat:'Missing Step',
      title:'No Reporting Step Defined',
      issue:'Your designed process has no documentation or report step.',
      cause:'Traceability requires a documented output for every completed process.',
      action:'Add a Report Generated or Document step at the end of the flow.',
      impact:'Ensures audit trail and regulatory compliance.'});
  }
  if(builderEdges.length<builderNodes.length-1){
    recs.push({id:'BR-'+recs.length,s:'warning',cat:'Design Gap',
      title:'Process Flow May Be Incomplete',
      issue:'You have '+builderNodes.length+' steps but only '+builderEdges.length+' connections. A linear process needs at least '+(builderNodes.length-1)+' connections.',
      cause:'Missing connections mean some steps cannot be reached.',
      action:'Connect all steps in sequence using the green port drag.',
      impact:'Ensures accurate total time estimation and valid comparison.'});
  }
  if(recs.length===0){
    recs.push({id:'BR-OK',s:'info',cat:'Status',
      title:'Well-Designed Process',
      issue:'No structural issues detected in your designed process.',
      cause:'All steps are connected, durations are balanced, and key steps are present.',
      action:'Compare with the mined process on the Comparison page to find real deviations.',
      impact:'Use this as the baseline for process improvement tracking.'});
  }

  // Render in a modal-style overlay on the builder page
  var existing=document.getElementById('builder-recs-panel');
  if(existing)existing.remove();
  var panel=document.createElement('div');
  panel.id='builder-recs-panel';
  panel.style.cssText='position:fixed;top:80px;right:20px;width:400px;max-height:70vh;overflow-y:auto;background:#fff;border:1px solid var(--border);border-radius:8px;box-shadow:0 8px 32px rgba(0,0,0,.15);z-index:500;padding:20px;';
  var html='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">'
    +'<div><div style="font-size:14px;font-weight:600">Process Recommendations</div>'
    +'<div style="font-size:10px;color:var(--textm);font-family:DM Mono,monospace">Based on your designed process . '+builderNodes.length+' steps . '+Math.round(totalDur/60*10)/10+'h total</div></div>'
    +'<button onclick="closeBuilderRecs()" style="background:none;border:none;font-size:20px;color:var(--textm);cursor:pointer;line-height:1">x</button></div>';
  recs.forEach(function(r){
    var bc=r.s==='critical'?'#c0392b':r.s==='warning'?'#b7770d':'#22883f';
    var bg=r.s==='critical'?'rgba(192,57,43,.05)':r.s==='warning'?'rgba(183,119,13,.05)':'rgba(0,78,43,.04)';
    html+='<div style="border-left:3px solid '+bc+';background:'+bg+';border-radius:0 4px 4px 0;padding:12px 14px;margin-bottom:10px">'
      +'<div style="display:flex;gap:6px;margin-bottom:6px"><span style="font-size:9px;background:'+bc+';color:#fff;padding:2px 6px;border-radius:2px;font-weight:600;text-transform:uppercase">'+r.s+'</span>'
      +'<span style="font-size:9px;color:var(--textm);border:1px solid var(--border);padding:2px 6px;border-radius:2px">'+r.cat+'</span></div>'
      +'<div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:8px">'+r.title+'</div>'
      +'<div style="font-size:11px;color:var(--textm);margin-bottom:4px"><b>Issue:</b> '+r.issue+'</div>'
      +'<div style="font-size:11px;color:var(--textm);margin-bottom:4px"><b>Action:</b> '+r.action+'</div>'
      +'<div style="font-size:11px;color:'+bc+';margin-top:6px;padding:6px 8px;background:rgba(0,0,0,.03);border-radius:3px"><b>Impact:</b> '+r.impact+'</div>'
      +'</div>';
  });
  panel.innerHTML=html;
  document.body.appendChild(panel);
  document.getElementById('builder-status').textContent='Generated '+recs.length+' recommendations from your process';
}

