.org-dept-card.active.director-dept { box-shadow:0 0 0 3px rgba(255,255,255,.4), 0 8px 28px rgba(14,74,40,.38), inset 0 1px 0 rgba(255,255,255,.12); }

.org-dept-accent { position:absolute; top:0; left:0; right:0; height:2.5px; border-radius:9px 9px 0 0; }

.org-dept-name { font-size:11px; font-weight:700; color:#1a3022; letter-spacing:-.01em; margin-top:3px; margin-bottom:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.org-dept-card.primary .org-dept-name,
.org-dept-card.director-dept .org-dept-name { color:#fff; font-size:12px; }
