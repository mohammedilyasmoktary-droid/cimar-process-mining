function renderBuilderEdgesOnly(){
  var svgEl=document.getElementById('builder-svg');
  if(!svgEl)return;
  // Remove all paths (edges) but keep defs
  var paths=svgEl.querySelectorAll('path,text');
  paths.forEach(function(p){if(p.parentNode===svgEl){svgEl.removeChild(p);}});
  builderEdges.forEach(function(e){
    var sNode=getNodeById(e.from),tNode=getNodeById(e.to);
    if(!sNode||!tNode)return;
    var sx=sNode.x+79,sy=sNode.y+64,tx=tNode.x+79,ty=tNode.y;
    var mid=(sy+ty)/2;
    var path=document.createElementNS('http://www.w3.org/2000/svg','path');
    path.setAttribute('d','M '+sx+' '+sy+' C '+sx+' '+mid+', '+tx+' '+mid+', '+tx+' '+ty);
    path.setAttribute('fill','none');path.setAttribute('stroke','#5eac2c');
    path.setAttribute('stroke-width','2.5');path.setAttribute('marker-end','url(#b-arrow)');path.setAttribute('opacity','0.8');
    svgEl.appendChild(path);
  });
}

