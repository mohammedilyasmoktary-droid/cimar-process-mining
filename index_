.org-dept-card.director-dept .org-dept-tag { color:rgba(255,255,255,.42); }

.org-dept-kpis { display:flex; flex-direction:column; gap:3px; }
.org-dept-kpi  { display:flex; justify-content:space-between; align-items:baseline; font-size:8.5px; font-family:'DM Mono',monospace; }
.org-kpi-lbl { color:#7a9a82; }
.org-kpi-val { font-weight:700; }
.org-kpi-val.good { color:#1a6b40; }
.org-kpi-val.warn { color:#c4820e; }
.org-kpi-val.bad  { color:#c0392b; }
.org-dept-card.primary .org-kpi-lbl,
.org-dept-card.director-dept .org-kpi-lbl { color:rgba(255,255,255,.48); }
.org-dept-card.primary .org-kpi-val,
.org-dept-card.director-dept .org-kpi-val { color:rgba(255,255,255,.9); }

.org-dept-badge { margin-top:7px; padding-top:6px; border-top:1px solid rgba(0,0,0,.06); font-size:7.5px; font-family:'DM Mono',monospace; color:#9db5a5; display:flex; align-items:center; gap:4px; letter-spacing:.06em; }
.org-dept-card.primary .org-dept-badge,
