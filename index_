var cmpData={A:null,B:null};

function loadCompareFile(input,side){
  var f=input.files[0];if(!f)return;
  var metaEl=document.getElementById('cmp-'+side.toLowerCase()+'-meta');
  metaEl.textContent='Reading '+f.name+'...';
  var reader=new FileReader();
  reader.onload=function(e){
    try{
      var txt=e.target.result;
      var lines=txt.trim().split('\n');
      if(lines.length<2)throw new Error('Empty file');
      var hdr=lines[0].split(',').map(function(h){return h.trim().replace(/^"|"$/g,'');});
      var ci=hdr.indexOf('case_id'),ai=hdr.indexOf('activity'),ti=hdr.indexOf('timestamp'),pi=hdr.indexOf('plant');
      if(ci<0||ai<0||ti<0)throw new Error('Missing columns');
      var rows=[];
      for(var i=1;i<lines.length;i++){
        var l=lines[i].trim();if(!l)continue;
        var cols=l.split(',').map(function(x){return x.trim().replace(/^"|"$/g,'');});
        var ts=safeParse(cols[ti]||'');
        if(cols[ci]&&cols[ai]&&!isNaN(ts.getTime()))rows.push({case_id:cols[ci],activity:cols[ai],timestamp:ts,plant:pi>=0?(cols[pi]||'?'):'?'});
      }
      if(!rows.length)throw new Error('No valid rows');
      rows.sort(function(a,b){return a.timestamp-b.timestamp;});
      // Analyse
      var cases=uniq(rows.map(function(r){return r.case_id;}));
      var byCase={};rows.forEach(function(r){if(!byCase[r.case_id])byCase[r.case_id]=[];byCase[r.case_id].push(r);});
      var durs=cases.map(function(cid){var ts=byCase[cid].map(function(r){return r.timestamp.getTime();});return(Math.max.apply(null,ts)-Math.min.apply(null,ts))/3600000;});
      durs.sort(function(a,b){return a-b;});
      var avg=durs.reduce(function(s,v){return s+v;},0)/durs.length;
      var p90=durs[Math.min(Math.floor(durs.length*.9),durs.length-1)]||0;
      var acts=uniq(rows.map(function(r){return r.activity;}));
      var actWaits={};
      cases.forEach(function(cid){
        var cr=byCase[cid].slice().sort(function(a,b){return a.timestamp-b.timestamp;});
        for(var i=0;i<cr.length-1;i++){
          var act=cr[i].activity;var w=(cr[i+1].timestamp.getTime()-cr[i].timestamp.getTime())/60000;
          if(!actWaits[act])actWaits[act]=[];actWaits[act].push(w);
        }
      });
      var actStats={};
      acts.forEach(function(a){var ws=actWaits[a]||[];ws.sort(function(x,y){return x-y;});actStats[a]={avg:ws.length?ws.reduce(function(s,v){return s+v;},0)/ws.length:0,p90:ws.length?ws[Math.floor(ws.length*.9)]||0:0,cnt:ws.length};});
      var reworkKW=['retest','reject','rework','redo','re-','failed'];
      var rwCases=cases.filter(function(cid){return byCase[cid].some(function(r){return reworkKW.some(function(k){return r.activity.toLowerCase().indexOf(k)>=0;});});});
      var bkts={'<2h':0,'2-4h':0,'4-6h':0,'6-8h':0,'8-12h':0,'>12h':0};
      durs.forEach(function(h){if(h<2)bkts['<2h']++;else if(h<4)bkts['2-4h']++;else if(h<6)bkts['4-6h']++;else if(h<8)bkts['6-8h']++;else if(h<12)bkts['8-12h']++;else bkts['>12h']++;});
      var topPath=null;var pathMap={};
      cases.forEach(function(cid){var seq=byCase[cid].map(function(r){return r.activity;}).join('->');pathMap[seq]=(pathMap[seq]||0)+1;});
      topPath=Object.keys(pathMap).sort(function(a,b){return pathMap[b]-pathMap[a];})[0]||'';

      cmpData[side]={name:f.name,cases:cases.length,avg:avg,p90:p90,rw:rwCases.length/cases.length*100,acts:acts,actStats:actStats,bkts:bkts,topPath:topPath,rows:rows};
      metaEl.textContent=f.name+' . '+cases.length+' cases . '+acts.length+' activities';
      document.getElementById('cmp-'+side.toLowerCase()+'-label').style.background='rgba(0,78,43,.06)';
      document.getElementById('cmp-'+side.toLowerCase()+'-label').style.borderColor='var(--green)';

      // Render top path as flow
      var steps=topPath.split('->').slice(0,8);
      var flowHtml='<div style="display:flex;flex-wrap:wrap;gap:4px;align-items:center">';
      steps.forEach(function(s,i){
        var col=side==='A'?'#004e2b':'#b7770d';
        var bg=side==='A'?'#f0f9f4':'#fffbf0';
        var border=side==='A'?'#a8d5b5':'#f5c87e';
        flowHtml+='<div style="padding:5px 9px;background:'+bg+';border:1.5px solid '+border+';border-radius:4px;font-size:10px;font-weight:500;color:'+col+'">'+s+'</div>';
        if(i<steps.length-1)flowHtml+='<span style="color:var(--textd);font-size:12px">-></span>';
      });
      flowHtml+='</div>';
      document.getElementById('cmp-'+side.toLowerCase()+'-flow').innerHTML=flowHtml;

      // If both loaded, show comparison
      if(cmpData.A&&cmpData.B)renderComparisonResults();
    }catch(err){metaEl.textContent='Error: '+err.message;}
  };
  reader.readAsText(f);
}

function renderComparisonResults(){
  var A=cmpData.A,B=cmpData.B;
  document.getElementById('cmp-empty').style.display='none';
  document.getElementById('cmp-kpis').style.display='block';

  // KPI comparison
  var metrics=[
    {label:'Total Cases',a:A.cases,b:B.cases,fmt:function(v){return v.toLocaleString();},higherBetter:true},
    {label:'Avg Cycle',a:A.avg,b:B.avg,fmt:function(v){return v.toFixed(1)+'h';},higherBetter:false},
    {label:'P90 Cycle',a:A.p90,b:B.p90,fmt:function(v){return v.toFixed(1)+'h';},higherBetter:false},
    {label:'Rework Rate',a:A.rw,b:B.rw,fmt:function(v){return v.toFixed(1)+'%';},higherBetter:false},
  ];
  var aKpi='',bKpi='',dKpi='';
  metrics.forEach(function(m){
    var diff=m.b-m.a;
    var better=m.higherBetter?(diff>0):(diff<0);
    var diffCol=diff===0?'var(--textm)':better?'#22883f':'#c0392b';
    var diffStr=(diff>0?'+':'')+m.fmt(diff);
    aKpi+='<div style="padding:10px 0;border-bottom:1px solid var(--border);font-family:DM Mono,monospace"><div style="font-size:9px;color:var(--textd);margin-bottom:3px">'+m.label+'</div><div style="font-size:16px;font-weight:600;color:#004e2b">'+m.fmt(m.a)+'</div></div>';
    bKpi+='<div style="padding:10px 0;border-bottom:1px solid var(--border);font-family:DM Mono,monospace"><div style="font-size:9px;color:var(--textd);margin-bottom:3px">'+m.label+'</div><div style="font-size:16px;font-weight:600;color:#b7770d">'+m.fmt(m.b)+'</div></div>';
    dKpi+='<div style="padding:10px 0;border-bottom:1px solid var(--border);font-family:DM Mono,monospace"><div style="font-size:9px;color:var(--textd);margin-bottom:3px">'+m.label+'</div><div style="font-size:16px;font-weight:600;color:'+diffCol+'">'+diffStr+'</div></div>';
  });
  document.getElementById('cmp-a-kpis').innerHTML=aKpi;
  document.getElementById('cmp-b-kpis').innerHTML=bKpi;
  document.getElementById('cmp-diff-kpis').innerHTML=dKpi;

  // Activity wait comparison
