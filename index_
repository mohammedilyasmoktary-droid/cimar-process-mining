              +'<td>'+cs.p+'</td><td style="color:var(--textm)">'+cs.e+'</td>'
              +'<td>'+(cs.r?'<span class="badge bw">Yes</span>':'<span style="color:var(--textd)">-</span>')+'</td>'
              +'<td><div class="mbar-wrap" style="height:6px"><div class="mbar-fill" style="width:'+Math.min(100,cs.h/slMx*100)+'%;background:#c0392b;height:100%"></div></div></td></tr>';
          });
          var slEl=document.getElementById('slow-tbl');if(slEl)slEl.innerHTML=slHtml;

          // Re-draw all charts
          requestAnimationFrame(function(){
            drawChart('c-dur',D.dur.l,D.dur.v,D.dur.v.map(function(v,i){var cs=['#22883f','#22883f','#22883f','#b7770d','#b7770d','#c0392b','#c0392b'];return cs[i]||'#22883f';}),185);
            var fa=D.acts.filter(function(a){return a.avg>0;});
            drawChart('c-act',fa.map(function(a){return a.a.split(' ')[0];}),fa.map(function(a){return a.avg;}),fa.map(function(a){return a.col;}),200);
            drawChart('c-plant',D.plants.map(function(p){return p.p;}),D.plants.map(function(p){return p.hrs;}),D.plants.map(function(p){return p.hrs>avgCycle*1.3?'#c0392b':p.hrs>avgCycle?'#b7770d':'#22883f';}),200);
            drawChart('c-ret',['With Rework','Clean'],[ reworkCases.length,cases.length-reworkCases.length],['#c0392b','#22883f'],155);
            // Re-render pages that have cached data
            // Refresh ALL pages so switching to any page shows new data
            renderRecs();
            renderVariants();
            renderHeatmap();
            renderDFG();
            renderBottlenecks();
            renderRework();
            initDashboard();
            updateCmdCenter();
          });

          msg.style.background='rgba(0,78,43,.1)';msg.style.color='#004e2b';
          msg.textContent='OK '+cases.length+' cases loaded . '+activities.length+' activities . all pages updated';
          setTimeout(function(){document.getElementById('um').classList.remove('open');},1800);

        }catch(err2){
          msg.style.background='rgba(192,57,43,.08)';msg.style.color='#c0392b';
          msg.textContent='Analysis error: '+err2.message;
          console.error(err2);
        }
      },80);
    }catch(err){
      msg.style.background='rgba(192,57,43,.08)';msg.style.color='#c0392b';
      msg.textContent='Error: '+err.message;
    }
  };
  reader.readAsText(f);
}

