function updatePageHeaders(dept) {
  var pages = dept.pages || {};

  // Helper: update a page header's h1 and p
  function setHeader(pageId, title, sub) {
    var page = document.getElementById('page-' + pageId);
    if (!page) return;
    var h1 = page.querySelector('.page-header h1');
    var p  = page.querySelector('.page-header p');
    if (h1 && title) h1.textContent = title;
    if (p  && sub)   p.textContent  = sub;
  }

  // Command Center subtitle already handled by topbar-dept-sub
  // Update each analysis page
  if (pages.variants)    setHeader('variants',    pages.variants.title,    pages.variants.sub);
  if (pages.heatmap)     setHeader('heatmap',     pages.heatmap.title,     pages.heatmap.sub);
  if (pages.bottlenecks) setHeader('bottlenecks', pages.bottlenecks.title, pages.bottlenecks.sub);
  if (pages.rework)      setHeader('rework',      pages.rework.title,      pages.rework.sub);
  if (pages.compare)     setHeader('compare',     pages.compare.title,     pages.compare.sub);
  if (pages.recommendations) setHeader('recommendations', pages.recommendations.title, pages.recommendations.sub);

  // Update the Recommendations page sub-description (it has a second line of text)
  if (pages.recommendations) {
    var recPage = document.getElementById('page-recommendations');
    if (recPage) {
      var recSub = recPage.querySelector('.page-header p');
      if (recSub) recSub.textContent = pages.recommendations.sub;
    }
  }

  // Update the rework loop description (it has a specific sub line about loop structure)
  if (pages.rework) {
    var rwPage = document.getElementById('page-rework');
    if (rwPage) {
      var rwSub = rwPage.querySelector('.page-header p');
      if (rwSub) rwSub.textContent = pages.rework.sub;
    }
  }

  // Update sidebar section label to show dept name
  var sideLabel = document.querySelector('.sidebar-section-label');
  if (sideLabel) sideLabel.textContent = dept.name + ' Pages';

  // Update nav badge on bottlenecks to be visible
  var bnBadge = document.querySelector('[data-page="bottlenecks"] .nav-badge');
  if (bnBadge && D.bns[0]) bnBadge.textContent = Math.round(D.bns[0].avg/60*10)/10 + 'h';

  // Update rework nav badge
  var rwBadge = document.querySelector('[data-page="rework"] .nav-badge');
  var rwPct = D.rw_plants.length ? Math.round(D.rw_plants.reduce(function(s,p){return s+p.rw;},0) / D.plants.reduce(function(s,p){return s+p.cnt;},0) * 100) : 25;
  if (rwBadge) rwBadge.textContent = rwPct + '%';
}

