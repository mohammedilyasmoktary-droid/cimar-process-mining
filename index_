/* Root connector */
.org-root-conn { width:2px; height:20px; background:linear-gradient(180deg,rgba(45,155,94,.5) 0%,rgba(45,155,94,.2) 100%); margin:0 auto; }

/*    DEPT BRANCH                                                          */
.org-dept-branch { display:flex; flex-direction:column; align-items:center; width:100%; }
.org-h-line {
  width:calc(100% - 40px); height:1px;
