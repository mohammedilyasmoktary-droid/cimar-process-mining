  // -- ROOT -------------------------------------------------------------------
  var rootRow = document.createElement('div');
  rootRow.className = 'org-root-row';
  var rootNode = document.createElement('div');
  rootNode.className = 'org-root-node';
  rootNode.innerHTML =
    '<div class="org-root-inner">'
    +'<img class="org-root-logo-img" src="data:image/png;base64," alt="Ciments du Maroc"/>'
    +'</div>'
    +'<div class="org-root-pills">'
    +'<span class="org-root-pill">8 Departments</span>'
    +'<span class="org-root-pill">4 Sites</span>'
    +'<span class="org-root-pill">5.3M t/yr</span>'
    +(isDirector?'<span class="org-root-pill role-pill">'+escHtml(userRole)+'</span>':'')
    +'</div>';
  rootRow.appendChild(rootNode);
  orgWrap.appendChild(rootRow);

  var rootConn = document.createElement('div');
  rootConn.className = 'org-root-conn';
  orgWrap.appendChild(rootConn);

  // -- DEPT + PROCESS COLUMNS -------------------------------------------------
  var deptBranch = document.createElement('div');
  deptBranch.className = 'org-dept-branch';
  var hLine = document.createElement('div');
  hLine.className = 'org-h-line';
  deptBranch.appendChild(hLine);

  var deptCols = document.createElement('div');
  deptCols.className = 'org-dept-cols';

  CHAIN.forEach(function(id){
    var s         = DEPT_SUMMARY[id];
    if(!s) return;
    var isGranted = access.indexOf(id) >= 0;
    var isPrimary = !isDirector && (id === primaryId);
    var statCol   = sCol[s.status]||'#7a9585';
    var processes = DEPT_PROCESSES[id]||[];

    var col = document.createElement('div');
    col.className = 'org-dept-col';
    col.dataset.id = id;

    var vConn = document.createElement('div');
    vConn.className = 'org-v-conn';
    col.appendChild(vConn);

    // -- Dept card -------------------------------------------------------------
    var card = document.createElement('div');
    // FIX 3: Directors get uniform green, dept users see primary highlight
    var cardClass = 'org-dept-card';
    if(isDirector && isGranted)       cardClass += ' director-dept';
    else if(isPrimary)                 cardClass += ' primary';
    else if(isGranted && !isPrimary)   cardClass += ' granted';
    else                               cardClass += ' restricted';
    card.className = cardClass;
    card.dataset.id = id;

    var accent = document.createElement('div');
    accent.className = 'org-dept-accent';
    accent.style.background = (isPrimary||isDirector) ? 'rgba(255,255,255,.25)' : statCol;
    card.appendChild(accent);

    var nm = document.createElement('div');
    nm.className = 'org-dept-name';
    nm.textContent = s.name.replace(' / Production','').replace(' Control','');
    card.appendChild(nm);

    var tg = document.createElement('div');
    tg.className = 'org-dept-tag';
    tg.textContent = s.tag;
    card.appendChild(tg);

    var kpiDiv = document.createElement('div');
    kpiDiv.className = 'org-dept-kpis';
    s.kpis.slice(0,2).forEach(function(k){
      var row = document.createElement('div'); row.className = 'org-dept-kpi';
      var l=document.createElement('span'); l.className='org-kpi-lbl'; l.textContent=k.l;
      var v=document.createElement('span'); v.className='org-kpi-val '+((isPrimary||isDirector)?'':k.c); v.textContent=k.v;
      row.appendChild(l); row.appendChild(v); kpiDiv.appendChild(row);
    });
    card.appendChild(kpiDiv);

    var badge = document.createElement('div');
    badge.className = 'org-dept-badge';
    var badgeLabel = isDirector && isGranted ? 'FULL ACCESS'
                    : isPrimary ? 'YOUR DEPT'
                    : isGranted ? 'GRANTED' : 'RESTRICTED';
    var badgeDot = (isPrimary||isDirector) ? 'rgba(255,255,255,.6)' : isGranted ? statCol : '#ef4444';
    var badgePrefix = (!isGranted) ? '<svg width="9" height="10" viewBox="0 0 9 10" fill="none" style="margin-right:3px;vertical-align:middle;flex-shrink:0"><rect x="1" y="4" width="7" height="6" rx="1.5" fill="#ef4444"/><path d="M2.5 4V3a2 2 0 0 1 4 0v1" stroke="#ef4444" stroke-width="1.2" stroke-linecap="round"/></svg>' : '<span class="org-badge-dot" style="background:'+badgeDot+'"></span>';
    badge.innerHTML = badgePrefix + badgeLabel;
    card.appendChild(badge);

    if(isGranted){
      card.onclick = function(){
        var did = this.dataset.id;
        document.querySelectorAll('.org-dept-card').forEach(function(c){ c.classList.remove('active'); });
        this.classList.add('active');
        _activeDept = did;
        // Update process tags for new selection
        document.querySelectorAll('.org-proc-node').forEach(function(pn){
          var pid   = pn.dataset.proc;
          var colEl = pn.closest('.org-dept-col');
          var dId   = colEl ? colEl.dataset.id : '';
          var isSel = !isDirector && dId === did;
          pn.className = 'org-proc-node' + (isSel?' primary-proc':'');
          var tagEl = pn.querySelector('.org-proc-tag');
          if(tagEl){
            var t = getProcTag(did, pid);
            tagEl.className = 'org-proc-tag tag-'+t.tag;
            tagEl.textContent = t.label;
            tagEl.style.display = t.label ? '' : 'none';
          }
        });
        showOrgCTA(did);
        if(!isDirector) dimNonRelated(did);
        else document.querySelectorAll('.org-dept-col').forEach(function(col){ col.style.opacity='1'; col.style.transform=''; });
      };
    }

    col.appendChild(card);

    // -- Process nodes ---------------------------------------------------------
    var pConn = document.createElement('div');
    pConn.className = 'org-proc-conn-v';
    col.appendChild(pConn);

    var procList = document.createElement('div');
    procList.className = 'org-proc-list';

    processes.forEach(function(proc, pi){
      if(pi>0){
        var sep=document.createElement('div');
        sep.className='org-proc-sep'; procList.appendChild(sep);
      }
      var pNode = document.createElement('div');
      var t = getProcTag(primaryId, proc.id);
      var isSel = !isDirector && id === primaryId;
      pNode.className = 'org-proc-node' + (isSel?' primary-proc':'')
        + (t.tag==='bad'?' impact-high':t.tag==='warn'?' impact-med':'');
      pNode.dataset.proc = proc.id;
      pNode.dataset.dept = id;
      pNode.dataset.insight = proc.insight||'';
      pNode.dataset.impactLabel = t.label||'';

      var nameDiv = document.createElement('div');
      nameDiv.className = 'org-proc-name';
      nameDiv.textContent = proc.name;

      var kpiDiv2 = document.createElement('div');
      kpiDiv2.className = 'org-proc-kpi';
      kpiDiv2.textContent = proc.kpi;

      pNode.appendChild(nameDiv);
      pNode.appendChild(kpiDiv2);

      if(t.label){
        var tagSpan = document.createElement('span');
        tagSpan.className = 'org-proc-tag tag-'+t.tag;
        tagSpan.textContent = t.label;
        pNode.appendChild(tagSpan);
      }

      // FIX 4: Process click - insight tooltip
      pNode.onclick = function(e){
        e.stopPropagation();
        showProcInsight(this);
      };

      procList.appendChild(pNode);
    });
    col.appendChild(procList);
    deptCols.appendChild(col);
  });

  deptBranch.appendChild(deptCols);
  orgWrap.appendChild(deptBranch);
  wrap.appendChild(orgWrap);

  // FIX 1: CTA goes to VERY BOTTOM - after orgWrap, as sibling ---------------
  var ctaBar = document.createElement('div');
  ctaBar.id = 'org-cta-bar';
  ctaBar.className = 'org-cta-bar';
  ctaBar.innerHTML =
    '<div class="org-cta-inner">'
    +'<div>'
    +'<div class="org-cta-dept" id="org-cta-dept-name"></div>'
    +'<div class="org-cta-sub">Click to open the full process analysis workspace</div>'
    +'</div>'
    +'<button class="org-cta-btn" id="org-cta-btn">Open Workspace &rarr;</button>'
    +'</div>';
  // Append CTA to view-access (parent of wrap) so it sits OUTSIDE the scroll area
  var viewAccess = document.getElementById('view-access');
  var existingCta = document.getElementById('org-cta-bar');
  if (existingCta) existingCta.parentNode.removeChild(existingCta);
  if (viewAccess) viewAccess.appendChild(ctaBar);
  else wrap.appendChild(ctaBar);

  // FIX 5: Process insight tooltip container
  var tooltip = document.getElementById('proc-insight-tooltip');
  if(!tooltip){
    tooltip = document.createElement('div');
    tooltip.id = 'proc-insight-tooltip';
    tooltip.className = 'proc-insight-tooltip';
    document.body.appendChild(tooltip);
    document.addEventListener('click', function(){ tooltip.classList.remove('visible'); });
  }

  // Auto-select
  setTimeout(function(){
    var primaryCard = document.querySelector('.org-dept-card.primary,.org-dept-card.director-dept');
    if(primaryCard) primaryCard.classList.add('active');
    showOrgCTA(primaryId);
  }, 120);
}

function showOrgCTA(deptId){
  var bar  = document.getElementById('org-cta-bar');
  var nm   = document.getElementById('org-cta-dept-name');
  var btn  = document.getElementById('org-cta-btn');
  var s    = DEPT_SUMMARY[deptId]||{};
  if(nm)  nm.textContent  = s.name || deptId;
  if(btn) btn.onclick = function(){ selectDept(deptId); };
  if(bar) bar.classList.add('visible');
}

function selectDept(deptId){
  var dept = DEPT_REGISTRY.filter(function(d){ return d.id === deptId; })[0];
  if(!dept) return;
  APP_STATE.selectedDept = dept;
  window._pendingDept    = dept;
  renderIntelView(dept);
  goToStep(3);
}

function renderIntelView(dept){
  var data   = CROSS_DEPT_IMPACT[dept.id] || {};
  var plants = DEPT_PLANT_PERF[dept.id]   || [];

  // Header
  var nm = document.getElementById('intel-dept-name');
  var sb = document.getElementById('intel-dept-sub');
  if(nm) nm.textContent = dept.name;
  if(sb) sb.textContent = (dept.tag||'') + ' - Jan-Apr 2026 - 4 sites';

  // -- LEFT: SVG relationship map ------------------------------------------
  var mapEl = document.getElementById('vi2-map');
  var svg = d3.select('#vi2-map');
  svg.selectAll('*').remove();

  if(mapEl){
    var W = mapEl.offsetWidth  || 420;
    var H = mapEl.offsetHeight || 560;
    svg.attr('viewBox','0 0 '+W+' '+H).style('width','100%').style('height','100%');

    var UP = data.upstream   || [];
    var DN = data.downstream || [];

    // Node dimensions - wider, taller for more presence
    var nW = 148, nH = 62;
    var centerX = W/2;
    var cW = 168, cH = 68;

    // Spread vertically: padding proportional to H
    var padV = Math.round(H * 0.085);
    var upY  = padV + nH/2;
    var cY   = H/2;
    var dnY  = H - padV - nH/2;

    // Severity colour
    function sevCol(s){ return s==='bad'?'#c0392b':s==='warn'?'#b7770d':'#22883f'; }
    function sevKey(s){ return s==='bad'?'bad':s==='warn'?'warn':'good'; }

    // Defs
    var defs = svg.append('defs');
    ['bad','warn','good','neutral'].forEach(function(k){
      var col = k==='bad'?'#c0392b':k==='warn'?'#b7770d':k==='good'?'#22883f':'#a0b8a8';
      defs.append('marker')
        .attr('id','arr2-'+k)
        .attr('viewBox','0 0 10 10').attr('refX',8).attr('refY',5)
        .attr('markerWidth',6).attr('markerHeight',6)
        .attr('orient','auto-start-reverse')
        .append('path').attr('d','M2 2L9 5L2 8')
        .attr('fill','none').attr('stroke',col)
        .attr('stroke-width',1.6).attr('stroke-linecap','round');
    });

    // White bg
    svg.append('rect').attr('x',0).attr('y',0).attr('width',W).attr('height',H).attr('fill','#fff');

    // Subtle section bg bands
    svg.append('rect').attr('x',0).attr('y',0).attr('width',W).attr('height',upY+nH/2+20)
      .attr('fill','rgba(240,248,244,.5)');
    svg.append('rect').attr('x',0).attr('y',dnY-nH/2-20).attr('width',W).attr('height',H-(dnY-nH/2-20))
      .attr('fill','rgba(240,248,244,.5)');

    //    TOOLTIP panel (HTML div, absolute positioned over SVG)                
    var tipId = 'vi2-node-tip';
    var existing = document.getElementById(tipId);
    if(existing) existing.parentNode.removeChild(existing);
    var tip = document.createElement('div');
    tip.id = tipId;
    tip.style.cssText = [
      'position:absolute','z-index:50','left:50%','bottom:16px',
      'transform:translateX(-50%)',
      'width:calc(100% - 40px)','max-width:360px',
      'background:#0e4a28','border-radius:12px',
      'padding:14px 16px','box-shadow:0 8px 28px rgba(10,40,22,.35)',
      'font-family:Plus Jakarta Sans,sans-serif',
      'transition:opacity .2s ease,transform .2s ease',
      'opacity:0','pointer-events:none',
      'border:1px solid rgba(93,186,133,.25)'
    ].join(';');
    mapEl.style.position = 'relative';
    mapEl.appendChild(tip);

    function showTip(nodeData, role){
      var col  = sevCol(nodeData.severity);
      var sevLabel = nodeData.severity==='bad'?'CRITICAL':nodeData.severity==='warn'?'WARNING':'HEALTHY';
      var chipBg = nodeData.severity==='bad'?'rgba(220,38,38,.22)':
                   nodeData.severity==='warn'?'rgba(183,119,13,.22)':'rgba(34,136,63,.22)';
      var roleLabel = role==='up' ? 'Upstream blocker' : 'Downstream impact';
      var impactLine = role==='up'
        ? 'Blocks this department with impact: <strong style="color:'+col+'">'+escHtml(nodeData.impact)+'</strong>'
        : 'This department cascades: <strong style="color:'+col+'">'+escHtml(nodeData.impact)+'</strong>';
      tip.innerHTML =
        '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">'
          +'<div style="width:10px;height:10px;border-radius:50%;background:'+col+';flex-shrink:0"></div>'
          +'<div style="font-size:14px;font-weight:800;color:#fff;letter-spacing:-.02em">'+escHtml(nodeData.dept)+'</div>'
          +'<span style="margin-left:auto;font-size:8px;font-weight:800;font-family:DM Mono,monospace;'
            +'padding:3px 8px;border-radius:4px;background:'+chipBg+';color:'+col+'">'+sevLabel+'</span>'
        +'</div>'
        +'<div style="font-size:10px;color:rgba(255,255,255,.55);font-family:DM Mono,monospace;'
          +'text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px">'+roleLabel+'</div>'
        +'<div style="font-size:12px;color:rgba(255,255,255,.82);line-height:1.55;margin-bottom:8px">'
          +escHtml(nodeData.desc||'No additional detail available.')+'</div>'
        +'<div style="font-size:11px;color:rgba(255,255,255,.65);font-family:DM Mono,monospace">'+impactLine+'</div>';
      tip.style.opacity = '1';
      tip.style.pointerEvents = 'auto';
      tip.style.transform = 'translateX(-50%) translateY(0)';
    }

    function hideTip(){
      tip.style.opacity = '0';
      tip.style.pointerEvents = 'none';
    }

    // Click on SVG bg hides tip
    svg.on('click', function(){ hideTip(); });

    //    EDGE DRAW                                                              
    function drawEdge(x1,y1,x2,y2,sev,label){
      var col = sevCol(sev);
      var sk  = sevKey(sev);
      var sw  = sev==='bad'?2.4:sev==='warn'?2:1.6;
      var cx1 = x1 + (x2-x1)*0.0;
      var cy1 = y1 + (y2-y1)*0.55;
      var cx2 = x2 + (x1-x2)*0.0;
      var cy2 = y2 - (y2-y1)*0.55;
      var d   = 'M'+x1+','+y1+' C'+x1+','+cy1+','+x2+','+cy2+','+x2+','+y2;
      svg.append('path').attr('d',d)
        .attr('fill','none').attr('stroke',col)
        .attr('stroke-width',sw).attr('opacity',.6)
        .attr('marker-end','url(#arr2-'+sk+')');
      if(label){
        var my = (y1+y2)/2;
        var mx = (x1+x2)/2;
        var tw = Math.max(label.length*5.8+14, 52);
        var bgPill = sev==='bad'?'rgba(220,38,38,.11)':sev==='warn'?'rgba(183,119,13,.11)':'rgba(34,136,63,.11)';
        svg.append('rect').attr('x',mx-tw/2).attr('y',my-9).attr('width',tw).attr('height',17).attr('rx',5)
          .attr('fill','#fff').attr('stroke',bgPill.replace('.11)','.35)')).attr('stroke-width',.8);
        svg.append('text').attr('x',mx).attr('y',my+1)
          .attr('text-anchor','middle').attr('dominant-baseline','middle')
          .attr('fill',col).attr('font-size',8.5)
          .attr('font-family','DM Mono,monospace').attr('font-weight','700').text(label);
      }
    }

    //    NODE DRAW                                                              
    function drawNodeCard(x, y, w, h, title, sub, subCol, isCenter, nodeData, role){
      var g = svg.append('g').attr('cursor', isCenter ? 'default' : 'pointer');
      var rx = 12;

      if(isCenter){
        var gId = 'cg-'+Math.round(Math.random()*1e6);
        var grad = defs.append('linearGradient')
          .attr('id',gId).attr('x1','0%').attr('y1','0%').attr('x2','100%').attr('y2','100%');
        grad.append('stop').attr('offset','0%').attr('stop-color','#0e4a28');
        grad.append('stop').attr('offset','100%').attr('stop-color','#1c7a48');
        var fId = 'sh'+gId;
        var filt = defs.append('filter').attr('id',fId).attr('x','-25%').attr('y','-25%').attr('width','150%').attr('height','150%');
        filt.append('feDropShadow').attr('dx',0).attr('dy',8).attr('stdDeviation',12).attr('flood-color','rgba(10,40,22,.3)');
        g.append('rect').attr('x',x-w/2).attr('y',y-h/2).attr('width',w).attr('height',h).attr('rx',rx)
          .attr('fill','url(#'+gId+')').attr('filter','url(#'+fId+')');
        g.append('text').attr('x',x).attr('y',y-8)
          .attr('text-anchor','middle').attr('dominant-baseline','middle')
          .attr('fill','#fff').attr('font-size',15).attr('font-weight','800')
          .attr('font-family','Plus Jakarta Sans,sans-serif').text(title);
        g.append('text').attr('x',x).attr('y',y+10)
          .attr('text-anchor','middle').attr('dominant-baseline','middle')
          .attr('fill','rgba(255,255,255,.65)').attr('font-size',9.5)
          .attr('font-family','DM Mono,monospace').text(sub);
      } else {
        var bgCol = subCol==='#c0392b'?'rgba(220,38,38,.06)':subCol==='#b7770d'?'rgba(183,119,13,.05)':'rgba(34,136,63,.07)';
        var bdCol = subCol==='#c0392b'?'rgba(220,38,38,.3)':subCol==='#b7770d'?'rgba(183,119,13,.35)':'rgba(34,136,63,.35)';
        var bg = g.append('rect').attr('x',x-w/2).attr('y',y-h/2).attr('width',w).attr('height',h).attr('rx',rx)
          .attr('fill',bgCol).attr('stroke',bdCol).attr('stroke-width',1.8);
        g.append('text').attr('x',x).attr('y',y-9)
          .attr('text-anchor','middle').attr('dominant-baseline','middle')
          .attr('fill','#0d1f13').attr('font-size',12).attr('font-weight','800')
          .attr('font-family','Plus Jakarta Sans,sans-serif').text(title);
        g.append('text').attr('x',x).attr('y',y+9)
          .attr('text-anchor','middle').attr('dominant-baseline','middle')
          .attr('fill',subCol).attr('font-size',9).attr('font-family','DM Mono,monospace')
          .text(sub);
        // Status dot
        g.append('circle').attr('cx',x+w/2-10).attr('cy',y-h/2+10).attr('r',5).attr('fill',subCol);

        // Hover + click
        g.on('mouseenter', function(){
          bg.attr('stroke-width',2.5).attr('fill',
            subCol==='#c0392b'?'rgba(220,38,38,.1)':subCol==='#b7770d'?'rgba(183,119,13,.09)':'rgba(34,136,63,.11)');
        });
        g.on('mouseleave', function(){
          bg.attr('stroke-width',1.8).attr('fill',bgCol);
        });
        g.on('click', function(event){
          event.stopPropagation();
          showTip(nodeData, role);
        });
      }
      return g;
    }

    //    SECTION LABELS                                                         
    function sectionLabel(text, y){
      svg.append('text').attr('x',W/2).attr('y',y)
        .attr('text-anchor','middle')
        .attr('font-size',8).attr('font-family','DM Mono,monospace')
        .attr('fill','#b0c8b8').attr('letter-spacing','.14em').attr('font-weight','700')
        .text(text);
    }

    //    DRAW                                                                   

    // Upstream
    if(UP.length) sectionLabel('UPSTREAM BLOCKERS', upY - nH/2 - 12);
    UP.forEach(function(u, i){
      var total = UP.length;
      // Spread horizontally with min 28px margin from edge
      var span  = W - nW - 56;
      var x = nW/2 + 28 + (total > 1 ? span/(total-1) * i : span/2);
      var col = sevCol(u.severity);
      var sk  = sevKey(u.severity);
      drawEdge(x, upY+nH/2, centerX, cY-cH/2, u.severity, u.impact);
      drawNodeCard(x, upY, nW, nH, u.dept, u.badge+' - blocks', col, false, u, 'up');
    });

    // Centre
    drawNodeCard(centerX, cY, cW, cH, dept.name, dept.tag||'', '#fff', true, null, null);

    // Downstream
    DN.forEach(function(d, i){
      var total = DN.length;
      var span  = W - nW - 56;
      var x = nW/2 + 28 + (total > 1 ? span/(total-1) * i : span/2);
      var col = sevCol(d.severity);
      var sk  = sevKey(d.severity);
      drawEdge(centerX, cY+cH/2, x, dnY-nH/2, d.severity, d.impact);
      drawNodeCard(x, dnY, nW, nH, d.dept, d.badge+' - impacted', col, false, d, 'dn');
    });
    if(DN.length) sectionLabel('DOWNSTREAM IMPACT', dnY + nH/2 + 16);

    // Empty state
    if(!UP.length && !DN.length){
      drawNodeCard(centerX, cY, cW, cH, dept.name, dept.tag||'', '#fff', true, null, null);
      svg.append('text').attr('x',centerX).attr('y',cY+cH/2+32)
        .attr('text-anchor','middle').attr('font-size',11)
        .attr('fill','#a0b8a8').attr('font-family','DM Mono,monospace')
        .text('No cross-department connections');
    }
  }

// -- RIGHT: KPI line -----------------------------------------------------
  var kpiEl = document.getElementById('intel-kpis');
  if(kpiEl && data.kpis){
    kpiEl.innerHTML = data.kpis.slice(0,5).map(function(k){
      return '<div class="pf-kpi">'
        +'<span class="pf-kpi-lbl">'+k.label+'</span>'
        +'<span class="pf-kpi-val '+k.tclass+'">'+k.value+'</span>'
        +'<span class="pf-kpi-trend '+k.tclass+'">'+k.trend+'</span>'
        +'</div>';
    }).join('');
  }

  // -- RIGHT: Process timeline ----------------------------------------------
  var tlEl = document.getElementById('intel-timeline');
  if(tlEl && dept.defaultActivities){
    var acts = dept.defaultActivities;
    var maxV = 1;
    var timings = acts.map(function(a,i){
      var val = i===Math.floor(acts.length*0.6)?185:i===0?12:30+i*10;
      if(val>maxV) maxV=val;
      return {name:a, val:val};
    });
    tlEl.innerHTML = timings.map(function(t,i){
      var pct = Math.round(t.val/maxV*100);
      var col = t.val>150?'#c0392b':t.val>60?'#b7770d':'#4a9b6b';
      var tag = t.val>150?'slow':t.val>60?'mod':'fast';
      var isLast = i===timings.length-1;
      return '<div class="pf-stage">'
        +'<div class="pf-stage-connector">'
        +'<div class="pf-stage-dot" style="background:transparent;border-color:'+col+';box-shadow:0 0 0 3px rgba(255,255,255,.12)"></div>'
        +(!isLast?'<div class="pf-stage-line" style="background:'+col+'22"></div>':'')
        +'</div>'
        +'<div class="pf-stage-body">'
        +'<span class="pf-stage-name">'+t.name+'</span>'
        +'<div class="pf-stage-bar"><div class="pf-stage-fill" style="width:'+pct+'%;background:'+col+'"></div></div>'
        +'<span class="pf-stage-time" style="color:'+col+'">'+t.val+'m</span>'
        +'<span class="pf-stage-tag '+tag+'">'+tag+'</span>'
        +'</div></div>';
    }).join('');
  }

  // -- RIGHT: Health --------------------------------------------------------
  var hEl = document.getElementById('intel-health');
  if(hEl && data.bottlenecks){
    hEl.innerHTML = data.bottlenecks.map(function(b){
      var cls = b.status==='critical'?'critical':b.status==='warning'?'warning':'notice';
      var dc  = b.status==='critical'?'#c0392b':b.status==='warning'?'#b7770d':'#7a9585';
      var chipBg  = cls==='critical'?'rgba(192,57,43,.09)':cls==='warning'?'rgba(183,119,13,.08)':'rgba(0,0,0,.05)';
      var chipCol = cls==='critical'?'#8b1c13':cls==='warning'?'#7a5200':'var(--e-ink-l)';
      return '<div class="pf-health-row">'
        +'<div class="pf-health-dot" style="background:'+dc+'"></div>'
        +'<span class="pf-health-level '+cls+'">'+cls.toUpperCase()+'</span>'
        +'<span class="pf-health-text">'+b.label+'</span>'
        +'<span class="pf-health-chip" style="background:'+chipBg+';color:'+chipCol+'">'+b.detail+'</span>'
        +'</div>';
    }).join('');
  }

  updateLeftPanel(3);
}


function populateDetailPanel(deptId){
  var panel  = document.getElementById('vax-detail-panel');
  var data   = CROSS_DEPT_IMPACT[deptId] || {};
  var summary= DEPT_SUMMARY[deptId] || {};
  var access = APP_STATE.accessDepts || [];
  var isGranted = access.indexOf(deptId) >= 0;

  if(!panel) return;

  // Name
  var nameEl = document.getElementById('vax-det-name');
  if(nameEl) nameEl.textContent = summary.name || deptId;

  // KPIs
  var kpiEl = document.getElementById('vax-det-kpis');
  if(kpiEl && data.kpis){
    kpiEl.innerHTML = data.kpis.slice(0,4).map(function(k){
      return '<div class="vax-det-kpi">'
        +'<span class="vax-det-klbl">'+escHtml(k.label)+'</span>'
        +'<span class="vax-det-kval '+escHtml(k.tclass||'')+'">'+escHtml(k.value)+'</span>'
        +'<span class="vax-det-ktrend">'+escHtml(k.trend||k.meta||'')+'</span>'
        +'</div>';
    }).join('');
  } else if(kpiEl && summary.kpis){
    kpiEl.innerHTML = summary.kpis.slice(0,4).map(function(k){
      return '<div class="vax-det-kpi">'
        +'<span class="vax-det-klbl">'+escHtml(k.l)+'</span>'
        +'<span class="vax-det-kval '+escHtml(k.c||'')+'">'+escHtml(k.v)+'</span>'
        +'</div>';
    }).join('');
  }

  // Upstream
  var upEl = document.getElementById('vax-det-upstream');
  if(upEl){
    var ups = data.upstream || [];
    upEl.innerHTML = ups.length ? ups.map(function(u){
      return '<div class="vax-det-row">'
        +'<span class="vax-det-badge" style="background:'+u.color+';color:'+u.textColor+'">'+escHtml(u.badge||u.dept||'')+'</span>'
        +'<span class="vax-det-arrow">&#8594;</span>'
        +'<span class="vax-det-desc">'+escHtml(u.desc||'')+'</span>'
        +'<span class="vax-det-pill '+escHtml(u.severity||'')+'">'+escHtml(u.impact||'')+'</span>'
        +'</div>';
    }).join('') : '<div style="font-size:10px;color:var(--e-ink-xl);padding:6px 0">No upstream blockers.</div>';
  }

  // Downstream
  var dnEl = document.getElementById('vax-det-downstream');
  if(dnEl){
    var dns = data.downstream || [];
    dnEl.innerHTML = dns.length ? dns.map(function(d){
      return '<div class="vax-det-row">'
        +'<span class="vax-det-badge" style="background:'+d.color+';color:'+d.textColor+'">'+escHtml(d.badge||d.dept||'')+'</span>'
        +'<span class="vax-det-arrow">&#8592;</span>'
        +'<span class="vax-det-desc">'+escHtml(d.desc||'')+'</span>'
        +'<span class="vax-det-pill '+escHtml(d.severity||'')+'">'+escHtml(d.impact||'')+'</span>'
        +'</div>';
    }).join('') : '<div style="font-size:10px;color:var(--e-ink-xl);padding:6px 0">No downstream impacts.</div>';
  }

  // Insights / bottlenecks
  var insEl = document.getElementById('vax-det-insights');
  if(insEl){
    var bns = data.bottlenecks || [];
    insEl.innerHTML = bns.length ? bns.map(function(b){
      var col=b.color||'#b7770d';
      var bg=b.status==='critical'?'rgba(192,57,43,.1)':b.status==='warning'?'rgba(183,119,13,.08)':'rgba(34,136,63,.08)';
      return '<div class="vax-det-insight">'
        +'<div class="vax-det-insight-dot" style="background:'+col+'"></div>'
        +'<div class="vax-det-insight-text">'+escHtml(b.label)
          +'<span class="vax-det-insight-tag" style="background:'+bg+';color:'+col+';margin-left:5px">'+escHtml(b.detail||'')+'</span>'
        +'</div>'
        +'</div>';
    }).join('') : '<div style="font-size:10px;color:var(--e-ink-xl);padding:6px 0">No alerts.</div>';
  }

  // Main insight
  var mainEl = document.getElementById('vax-det-insight-main');
  if(mainEl){
    var bn0 = data.bottlenecks && data.bottlenecks[0];
    mainEl.textContent = bn0 ? bn0.label+' ('+bn0.detail+').' :
      (summary.name||deptId)+' is operating within normal parameters.';
  }

  // CTA
  var ctaEl = document.getElementById('vax-det-cta');
  if(ctaEl){
    ctaEl.disabled = !isGranted;
    ctaEl.onclick  = isGranted ? function(){ selectDept(deptId); } : null;
  }

  // Show panel
  panel.classList.add('visible');
}



function showProcInsight(node){
  var tooltip = document.getElementById('proc-insight-tooltip');
  if(!tooltip) return;
  var deptId  = node.dataset.dept || '';
  var procId  = node.dataset.proc || '';
  var insight = node.dataset.insight || '';
  var impLbl  = node.dataset.impactLabel || '';
  var tag     = node.querySelector('.org-proc-tag');
  var tagClass= tag ? tag.className.replace('org-proc-tag ','') : 'tag-neutral';

  var deptName = (DEPT_SUMMARY[deptId]||{name:deptId}).name || deptId;
  var procName = node.querySelector('.org-proc-name');
  procName = procName ? procName.textContent : procId;
  var activeDeptName = (DEPT_SUMMARY[_activeDept||'lab']||{name:'selected dept'}).name || 'selected dept';

  var dotColor = tagClass==='tag-bad'?'#c0392b':tagClass==='tag-warn'?'#c4820e':tagClass==='tag-sel'?'#0e4a28':'#1a6b40';
  tooltip.innerHTML =
    '<div class="pit-header">'
    +'<div class="pit-dot" style="background:'+dotColor+'"></div>'
    +'<div>'
    +'<div class="pit-proc">'+escHtml(procName)+'</div>'
    +'<div class="pit-dept">'+escHtml(deptName)+'</div>'
    +'</div>'
    +(impLbl?'<span class="pit-tag tag-'+tagClass.replace('tag-','')+'">'+escHtml(impLbl)+'</span>':'')
    +'</div>'
    +(insight?'<div class="pit-insight">'+escHtml(insight)+'</div>':'')
    +'<div class="pit-footer">Impact on: <strong>'+escHtml(activeDeptName)+'</strong></div>';

  var rect = node.getBoundingClientRect();
  var tx   = Math.min(rect.left + rect.width/2 - 150, window.innerWidth - 320);
  var ty   = rect.bottom + 8 + window.scrollY;
  tooltip.style.left = Math.max(8, tx) + 'px';
  tooltip.style.top  = ty + 'px';
  tooltip.classList.add('visible');
}


function dimNonRelated(deptId){
  var links = DEPT_LINKS[deptId]||{upstream:[],downstream:[]};
  var related = [deptId].concat(links.upstream||[]).concat(links.downstream||[]);
  document.querySelectorAll('.org-dept-col').forEach(function(col){
    var id = col.dataset.id;
    var isRel = related.indexOf(id)>=0;
    col.style.opacity   = isRel ? '1' : '0.45';
    col.style.transform = isRel ? '' : 'scale(0.97)';
  });
}


function highlightConnections(deptId){
  // Dim all dept cards except connected ones
  var links = DEPT_LINKS[deptId]||{upstream:[],downstream:[]};
  var related = [deptId].concat(links.upstream||[]).concat(links.downstream||[]);
  document.querySelectorAll('.org-dept-col').forEach(function(col){
    var id = col.dataset.id;
    col.style.opacity = related.indexOf(id)>=0 ? '1' : '0.4';
    col.style.transform = related.indexOf(id)>=0 ? '' : 'scale(0.97)';
  });
  // Highlight the active card
  document.querySelectorAll('.org-dept-card').forEach(function(card){
    card.classList.toggle('highlighted', card.dataset.id === deptId);
  });
}

function clearHighlights(){
  document.querySelectorAll('.org-dept-col').forEach(function(col){
    col.style.opacity=''; col.style.transform='';
  });
  document.querySelectorAll('.org-dept-card').forEach(function(c){
    c.classList.remove('highlighted');
  });
}

// DEPT_LINKS stays the same
var DEPT_LINKS = {
  lab:         {upstream:['kiln','procurement'],          downstream:['quality','dispatch','grinding']},
  kiln:        {upstream:['procurement','maintenance'],   downstream:['grinding','lab','dispatch']},
  grinding:    {upstream:['kiln'],                        downstream:['dispatch','quality']},
  quality:     {upstream:['lab','grinding'],              downstream:['dispatch']},
  maintenance: {upstream:['procurement'],                 downstream:['kiln']},
  logistics:   {upstream:['dispatch'],                    downstream:[]},
  dispatch:    {upstream:['lab','quality','grinding'],    downstream:['logistics']},
  procurement: {upstream:[],                              downstream:['kiln','maintenance','lab']}
};

function getLinkType(from,to){
  var lk=(NETWORK_LINKS||[]).filter(function(l){return l.s===from&&l.t===to;})[0];
  return lk?lk.type:'warn';
}
function getLinkLabel(from,to){
  var lk=(NETWORK_LINKS||[]).filter(function(l){return l.s===from&&l.t===to;})[0];
  return lk?lk.label:'';
}


function updateLeftPanel(step){
  var el = document.getElementById('em-left-body');
  if(!el) return;
  var fn = LEFT_PANELS[step] || LEFT_PANELS[1];
  el.innerHTML = fn();
}

// ---- STEP 1: Login ----
function getProcTag(primaryId, procId) {
  var map = PROC_IMPACT[primaryId] || {};
  return map[procId] || {tag:'neutral', label:'', insight:''};
}

function escHtml(s){
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ---- Step navigation ----
window.addEventListener('load',function(){
  // Wire up nav clicks
  document.querySelectorAll('.nav-item').forEach(function(el){
    el.addEventListener('click',function(){navTo(el.dataset.page);});
  });
  // Clear any stored dept so login screen always shows on page load
  try{localStorage.removeItem('cimar_active_dept');}catch(e){}
  ACTIVE_DEPT = null;
  // Render entry screen cards and overview stats
  renderEntryScreen();
  renderOverview();
  var entryEl = document.getElementById('entry-screen');
  if (entryEl) entryEl.classList.remove('hidden');
  // Start animated canvas after a tick so offsetWidth is valid
  setTimeout(function(){
    initSplashCanvas();
  }, 30);
  // Auto-dismiss splash after 2.8s
  window._splashTimer = setTimeout(function(){ dismissSplash(); }, 2800);
  setTimeout(function(){
    // Only draw charts for the active (visible) page
    var activePage=document.querySelector('.page.active');
    if(activePage){
      var cDur=document.getElementById('c-dur');
      if(cDur&&cDur.offsetParent!==null){drawChart('c-dur',D.dur.l,D.dur.v,durColors(),185);}
    }
    renderRecs();
    // Sparklines - use requestAnimationFrame to ensure layout is complete
    // Animate KPI numbers counting up
    var kpiAnims=[
      {id:'kpi-cases',  end:1000, fmt:function(v){return Math.round(v).toLocaleString();}},
      {id:'kpi-rework', end:25.3, fmt:function(v){return v.toFixed(1)+'%';}},
      {id:'kpi-approval',end:3.3, fmt:function(v){return v.toFixed(1)+'h';}},
      {id:'kpi-cycle',  end:6.3,  fmt:function(v){return v.toFixed(1)+'h';}},
    ];
    kpiAnims.forEach(function(k){
      var el=document.getElementById(k.id);if(!el)return;
      var start=0,dur=900,t0=performance.now();
      function step(now){
        var prog=Math.min(1,(now-t0)/dur);
        var ease=1-Math.pow(1-prog,3);
        el.textContent=k.fmt(start+ease*(k.end-start));
        if(prog<1)requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    });
    requestAnimationFrame(function(){
      drawSpark('spark-cases',   [820,850,880,930,970,1000], true);
      drawSpark('spark-cycle',   [7.1,6.9,6.8,6.6,6.4,6.3],  false);
      drawSpark('spark-rework',  [22.1,23.0,23.5,24.2,25.1,25.3], false);
      drawSpark('spark-approval',[2.8,2.9,3.0,3.1,3.2,3.3],  false);
    });
  },80);
});
