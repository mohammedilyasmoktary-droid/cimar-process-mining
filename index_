// Build per-plant edge data from raw rows if available
function getPlantEdges(plant){
  if(plant==='all'||!window._rawRows)return D.edges;
  var rows=window._rawRows.filter(function(r){return r.plant===plant;});
  var cases={};
  rows.forEach(function(r){if(!cases[r.case_id])cases[r.case_id]=[];cases[r.case_id].push(r);});
  var edgeMap={},edgeTime={};
  Object.keys(cases).forEach(function(cid){
    var cr=cases[cid].slice().sort(function(a,b){return a.timestamp-b.timestamp;});
    for(var i=0;i<cr.length-1;i++){
      var key=cr[i].activity+'|||'+cr[i+1].activity;
      edgeMap[key]=(edgeMap[key]||0)+1;
      if(!edgeTime[key])edgeTime[key]=[];
      edgeTime[key].push((cr[i+1].timestamp-cr[i].timestamp)/60000);
    }
  });
  return Object.keys(edgeMap).map(function(k){
    var parts=k.split('|||');
    var times=edgeTime[k];
    var avg=times.reduce(function(s,v){return s+v;},0)/times.length;
    return{f:parts[0],t:parts[1],c:edgeMap[k],avg:parseFloat(avg.toFixed(1))};
  }).sort(function(a,b){return b.c-a.c;});
}

function getPlantNodes(plant){
  if(plant==='all'||!window._rawRows)return null;
  var rows=window._rawRows.filter(function(r){return r.plant===plant;});
  var actWaits={};var actCounts={};
  var cases={};
  rows.forEach(function(r){if(!cases[r.case_id])cases[r.case_id]=[];cases[r.case_id].push(r);});
  Object.keys(cases).forEach(function(cid){
    var cr=cases[cid].slice().sort(function(a,b){return a.timestamp-b.timestamp;});
    cr.forEach(function(r){actCounts[r.activity]=(actCounts[r.activity]||0)+1;});
    for(var i=0;i<cr.length-1;i++){
      var act=cr[i].activity;
      var wait=(cr[i+1].timestamp-cr[i].timestamp)/60000;
      if(wait>=0){if(!actWaits[act])actWaits[act]=[];actWaits[act].push(wait);}
    }
  });
  var result={};
  Object.keys(actCounts).forEach(function(a){
    var waits=actWaits[a]||[];
    var avg=waits.length?waits.reduce(function(s,v){return s+v;},0)/waits.length:0;
    result[a]={cnt:actCounts[a],avg:parseFloat(avg.toFixed(1))};
  });
  return result;
}

