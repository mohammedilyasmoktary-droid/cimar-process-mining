}
.org-dept-card.director-dept:hover { transform:translateY(-3px); box-shadow:0 5px 20px rgba(14,74,40,.32), inset 0 1px 0 rgba(255,255,255,.12); }

/* Active state */
.org-dept-card.active:not(.primary):not(.director-dept) { box-shadow:0 0 0 2px #2d9b5e, 0 6px 20px rgba(14,74,40,.16); background:#daeae0; }
