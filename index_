function enterDepartment(deptId) {
  // 1. Resolve department config - fall back to lab if unknown
  var dept = DEPT_REGISTRY.filter(function(d){ return d.id === deptId; })[0];
  if (!dept) dept = DEPT_REGISTRY[0];

  ACTIVE_DEPT = dept;

  // 2. No persistence - login always shown on fresh load

  // 3. Update CIMAR_USER plant context (from previous session feature)
  // Department is separate from plant - plant is a sub-filter within a dept
  CIMAR_USER.dept = dept.id;

  // 4. Update topbar subtitle to reflect the department
  var sub = document.getElementById('topbar-dept-sub');
  if (sub) sub.textContent = dept.subtitle;

  // 5. Update sidebar "Your department" indicator
  var deptLabel = document.getElementById('sidebar-dept-label');
  if (deptLabel) deptLabel.textContent = dept.name;

  // 6. Build department-appropriate sample D if no CSV has been uploaded yet
  // This gives each department a meaningful default process map on first load
  if (!window._rawRows) {
    buildDeptSampleData(dept);
  }

  // 7. Apply department highlighting to sidebar plant rows (from prev feature)
  applyDeptHighlighting();

  // 8. Update all page titles and subtitles for this department
  updatePageHeaders(dept);

  // 9. Hide entry screen and reveal platform shell
  var entry = document.getElementById('entry-screen');
  if (entry) entry.classList.add('hidden');

  // 10. Update sidebar live metrics from fresh D
  var ssM=document.getElementById('ss-cases');
  if(ssM){
    var totCases=D.plants.reduce(function(s,p){return s+p.cnt;},0)||1000;
    var rwTotal=D.rw_plants.reduce(function(s,p){return s+p.rw;},0)||253;
    var rwPct=totCases?Math.round(rwTotal/totCases*1000)/10:25.3;
    var avgCyc=D.plants.length?D.plants.reduce(function(s,p){return s+p.hrs;},0)/D.plants.length:6.3;
    var ssEl=document.getElementById('ss-cases');if(ssEl)ssEl.textContent=totCases.toLocaleString();
    var scEl=document.getElementById('ss-cycle');if(scEl)scEl.textContent=avgCyc.toFixed(1)+'h';
    var srEl=document.getElementById('ss-rework');if(srEl)srEl.textContent=rwPct.toFixed(1)+'%';
    var spEl=document.querySelectorAll('.ss-plant-row');
    D.plants.forEach(function(p,i){
      if(spEl[i]){
        var valEl=spEl[i].querySelector('.ss-val');
        if(valEl)valEl.textContent=p.hrs.toFixed(1)+'h';
      }
    });
  }

  // 11. Render the command center (DFG + KPIs) for this department
  requestAnimationFrame(function() {
    renderDFG();
    updateCmdCenter();
    renderRecs();
    renderVariants();
    renderHeatmap();
    renderBottlenecks();
    renderRework();
    initDashboard();
  });

  // 11. Announce to screen readers
  var live = document.getElementById('sr-live');
  if (live) live.textContent = 'Entered ' + dept.name + ' department process view';
}

// =========================================================================
// DEPARTMENT SAMPLE DATA BUILDER
// Generates a plausible D structure for each department so the platform
// is immediately useful before any CSV is uploaded.
// The shape matches exactly what doUpload() produces.
// =========================================================================
function buildDeptSampleData(dept) {
  var acts = dept.defaultActivities;
  var n = acts.length;

  // Build acts array - assign realistic wait times
  // First and last activities are fast; middle ones may be slow
  D.acts = acts.map(function(name, i) {
    var isFirst = i === 0;
    var isLast = i === n - 1;
    var isMid = i > 0 && i < n - 1;
    // Bottleneck is at 60% through the process
    var isBottleneck = i === Math.floor(n * 0.6);
    var isRework = name.toLowerCase().indexOf('retest') >= 0
      || name.toLowerCase().indexOf('reject') >= 0
      || name.toLowerCase().indexOf('non-conformance') >= 0
      || name.toLowerCase().indexOf('corrective') >= 0;
    var avg = isFirst ? 12 : isLast ? 18 : isBottleneck ? 185 : isRework ? 65 : isMid ? 45 : 30;
    return {
      a: name, cnt: isFirst ? 1000 : isLast ? 985 : isRework ? 420 : 1000,
      avg: avg, p90: Math.round(avg * 2.1), max: Math.round(avg * 10), col: '#22883f'
    };
  });

  // bns = top bottlenecks sorted by avg desc
  D.bns = D.acts.slice().sort(function(a,b){return b.avg - a.avg;}).slice(0, 5);

  // Plants stay the same across departments - they are physical sites
  D.plants = [
    {p:'Casablanca', cnt:280, hrs:4.7, rw:22},
    {p:'Safi',       cnt:320, hrs:5.4, rw:24},
    {p:'Agadir',     cnt:200, hrs:6.6, rw:26},
    {p:'Marrakech',  cnt:200, hrs:8.6, rw:28}
  ];

  // rw_plants
  D.rw_plants = D.plants.map(function(p){
    return {p:p.p, rw:Math.round(p.cnt*p.rw/100), tot:p.cnt, pct:p.rw};
  });

  // edges - linear flow + one rework loop
  D.edges = [];
  for (var i = 0; i < n - 1; i++) {
    D.edges.push({f:acts[i], t:acts[i+1], c:980, avg:D.acts[i].avg});
  }
  // Add rework loop from last-before-end back to midpoint
  if (n >= 4) {
    D.edges.push({f:acts[Math.floor(n*0.6)], t:acts[Math.floor(n*0.4)], c:420, avg:65});
  }

  // variants
  var mainPath = acts.slice();
  var reworkPath = acts.slice(0, Math.floor(n*0.6)+1).concat(acts.slice(Math.floor(n*0.4)));
  D.variants = [
    {v:mainPath, c:705, p:70.5, s:mainPath.length, r:false, avgH:5.8},
    {v:reworkPath, c:126, p:12.6, s:reworkPath.length, r:true, avgH:8.2},
    {v:mainPath.slice(0,-1), c:92, p:9.2, s:mainPath.length-1, r:false, avgH:4.9},
    {v:acts.slice(0,Math.floor(n/2)), c:77, p:7.7, s:Math.floor(n/2), r:false, avgH:3.1}
  ];

  // dur
  D.dur = {
    l:['<2h','2-4h','4-6h','6-8h','8-12h','12-24h','>24h'],
    v:[45, 280, 350, 185, 90, 35, 15]
  };

  // slow
  D.slow = [
    {id:'C0103',h:38.3,p:'Marrakech',e:8,r:true},
    {id:'C0060',h:33.0,p:'Marrakech',e:7,r:false},
    {id:'C0400',h:32.5,p:'Agadir',e:9,r:true}
  ];

  // hm
  var plantsArr = ['Safi','Agadir','Marrakech','Casablanca'];
  D.hm = {
    acts: acts.slice(0, 7),
    plants: plantsArr,
    avg: acts.slice(0,7).map(function(a,i){
      var base = D.acts[i] ? D.acts[i].avg : 30;
      return [base*0.9, base*1.2, base*1.5, base*0.7];
    }),
    p90: acts.slice(0,7).map(function(a,i){
      var base = D.acts[i] ? D.acts[i].avg : 30;
      return [base*1.5, base*1.9, base*2.3, base*1.2];
    })
  };

  // recs - generated from the dept bottleneck
  var bn = D.bns[0];
  D.recs = [
    {id:'REC-001',s:'critical',cat:'Bottleneck',
     title: bn.a + ' Stage Delay',
     issue: bn.avg + 'm avg wait (threshold 2h). P90 ' + Math.round(bn.p90/60*10)/10 + 'h.',
     cause: 'Resource bottleneck or missing escalation procedure.',
     action: '1. Assign backup resource. 2. Set SLA alerts after 2h. 3. Auto-escalate.',
     impact: 'Reducing by 50% saves ~' + Math.round(bn.avg*500/60) + 'h per period.'},
    {id:'REC-002',s:'warning',cat:'Quality',
     title: 'Rework Rate Above Threshold',
     issue: '25.3% rework rate exceeds 15% threshold.',
     cause: 'Process inconsistency or calibration issues.',
     action: '1. Audit non-conformance patterns. 2. Pre-step checklists.',
     impact: 'Fixing rework for 253 cases saves significant cycle time.'}
  ];

  // sparkData
  D.sparkData = {
    cases:[820,870,910,950,980,1000],
    cycle:[7.1,6.9,6.7,6.4,6.3,6.3],
    rework:[22.1,22.8,23.4,24.1,24.8,25.3],
    approval:[2.8,2.9,3.0,3.1,3.2,3.3]
  };
}

