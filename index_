function resolveAccess(email){
  var key = email.toLowerCase().trim();
  if(ACCESS_MAP[key]){
    var m = ACCESS_MAP[key];
    return {email:email, role:m.role, primary:m.primary, extra:m.extra, access:[m.primary].concat(m.extra)};
  }
  var prefix = key.split('@')[0];
  var ids = ['lab','kiln','grinding','quality','maintenance','logistics','dispatch','procurement'];
  var match = ids.filter(function(id){ return prefix.indexOf(id) >= 0; });
  var primary = match.length ? match[0] : 'lab';
  return {email:email, role:'Department User', primary:primary, extra:[], access:[primary]};
}

