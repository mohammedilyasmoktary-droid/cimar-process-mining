.org-dept-card.restricted:hover { transform:none; }

/* FIX 3: Primary (dept user's own dept) */
.org-dept-card.primary {
  background:linear-gradient(135deg,#0e4a28 0%,#1a6b40 60%,#0d3d22 100%);
  border-color:rgba(45,155,94,.4);
